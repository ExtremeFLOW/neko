module test_parallel
  use mpi
  use pfunit
  use comm, only : NEKO_COMM, pe_rank, pe_size
  use device, only : device_init, device_finalize
  use neko_config, only : NEKO_BCKND_DEVICE
  use neko_mpi_types, only : neko_mpi_types_init, neko_mpi_types_free
  implicit none

  @TestCase
  type, extends(MPITestCase) :: parallel_template_case
   contains
     procedure :: setUp
     procedure :: tearDown
  end type parallel_template_case

contains

  subroutine setUp(this)
    class(parallel_template_case), intent(inout) :: this
    integer :: ierr
    if (NEKO_BCKND_DEVICE .eq. 1) then
       call device_init
    end if
    call MPI_Comm_dup(this%getMpiCommunicator(), NEKO_COMM%mpi_val, ierr)
    call neko_mpi_types_init()
  end subroutine setUp

  subroutine tearDown(this)
    class(parallel_template_case), intent(inout) :: this
    call neko_mpi_types_free()
    if (NEKO_BCKND_DEVICE .eq. 1) then
       call device_finalize
    end if
  end subroutine tearDown

  !> Verify that the parallel test template is wired correctly.
  @test(npes=[1])
  subroutine test_parallel_template_passes(this)
    class(parallel_template_case), intent(inout) :: this
    integer :: ierr, comm_size

    pe_rank = this%getProcessRank()
    pe_size = this%getNumProcesses()
    call MPI_Comm_size(NEKO_COMM%mpi_val, comm_size, ierr)

    @assertEqual(0, ierr)
    @assertEqual(1, pe_size)
    @assertEqual(1, comm_size)
    @assertTrue(pe_rank >= 0)
  end subroutine test_parallel_template_passes

end module test_parallel
