ifneq ("$(wildcard @PFUNIT_DIR@/include/PFUNIT.mk)", "")
include @PFUNIT_DIR@/include/PFUNIT.mk
endif
FFLAGS += $(PFUNIT_EXTRA_FFLAGS) @NEKO_PKG_FCFLAGS@ -I@top_builddir@/src
FC = @FC@

%.o : %.F90
	$(FC) -c $(FFLAGS) $<


check: serial_test

serial_test_TESTS := test_serial.pf

serial_test_OTHER_LIBRARIES = -L@top_builddir@/src/.libs -lneko @LDFLAGS@ @LIBS@
$(eval $(call make_pfunit_test,serial_test))
serial_test.inc: Makefile

distclean:
clean:
	$(RM) *.o *.mod *.a *.inc *.F90 serial_test



all:
html:
install:
distdir:
