module test_serial

  @TestCase
  type, extends(MPITestCase) :: serial_template_case
   contains
     procedure :: setUp
     procedure :: tearDown
  end type serial_template_case

contains

  subroutine setUp(this)
    class(test_fld_file_write), intent(inout) :: this
    integer :: ierr
    if (NEKO_BCKND_DEVICE .eq. 1) then
      call device_init
    end if
    call MPI_Comm_dup(this%getMpiCommunicator(), NEKO_COMM%mpi_val, ierr)
    call neko_mpi_types_init
  end subroutine setUp

  subroutine tearDown(this)
    class(test_fld_file_write), intent(inout) :: this
    if (NEKO_BCKND_DEVICE .eq. 1) then
      call device_finalize
    end if
  end subroutine tearDown

  !> Verify that the serial test template is wired correctly.
  @test
  subroutine test_serial_template_passes()
    use pfunit
    implicit none

    @assertTrue(.true.)
  end subroutine test_serial_template_passes

end module test_serial
