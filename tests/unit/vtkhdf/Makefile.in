USEMPI=YES
ifneq ("$(wildcard @PFUNIT_DIR@/include/PFUNIT.mk)", "")
include @PFUNIT_DIR@/include/PFUNIT.mk
endif
FFLAGS += $(PFUNIT_EXTRA_FFLAGS) @NEKO_PKG_FCFLAGS@ -I@top_builddir@/src
FC = @FC@

%.o : %.F90
	$(FC) -c $(FFLAGS) $<


check: vtkhdf_suite


vtkhdf_suite_TESTS := vtkhdf_parallel.pf
vtkhdf_suite_OTHER_LIBRARIES = -L@top_builddir@/src/.libs -lneko @LDFLAGS@ @LIBS@
$(eval $(call make_pfunit_test,vtkhdf_suite))

distclean:
clean:
	$(RM) *.o *.mod *.a  *.inc *.F90 vtkhdf_suite test_write*.vtkhdf



all:
html:
install:
distdir:
