module vtkhdf_parallel
  use mpi
  use pfunit
  use field, only : field_t
  use field_math, only : field_cfill
  use file, only : file_t
  use vtkhdf_file, only : vtkhdf_file_t
  use mesh, only : mesh_t
  use point, only : point_t
  use space, only : space_t, GLL
  use num_types, only : rp
  use device, only : device_init, device_finalize
  use dofmap, only : dofmap_t
  use comm, only : NEKO_COMM, pe_rank, pe_size
  use neko_config, only : NEKO_BCKND_DEVICE
  use hdf5, only : h5open_f, h5close_f, h5fopen_f, h5fclose_f, &
       h5gopen_f, h5gclose_f, h5aopen_f, h5aclose_f, h5aread_f, &
       h5dopen_f, h5dclose_f, h5dget_space_f, h5dread_f, &
       h5sget_simple_extent_dims_f, h5sget_simple_extent_ndims_f, &
       h5sclose_f, h5lexists_f, &
       hid_t, hsize_t, H5F_ACC_RDONLY_F, H5T_NATIVE_INTEGER, H5T_NATIVE_DOUBLE
  implicit none

  @TestCase
  type, extends(MPITestCase) :: test_vtkhdf
   contains
     procedure :: setUp
     procedure :: tearDown
  end type test_vtkhdf

contains

  subroutine setUp(this)
    class(test_vtkhdf), intent(inout) :: this
    if (NEKO_BCKND_DEVICE .eq. 1) then
       call device_init
    end if
  end subroutine setUp

  subroutine tearDown(this)
    class(test_vtkhdf), intent(inout) :: this
    if (NEKO_BCKND_DEVICE .eq. 1) then
       call device_finalize
    end if
  end subroutine tearDown

  subroutine test_vtkhdf_gen_msh(msh)
    type(mesh_t), intent(inout) :: msh
    type(point_t) :: p(12)

    call p(1)%init(0.0_rp, 0.0_rp, 0.0_rp)
    call p(1)%set_id(1)
    call p(2)%init(1.0_rp, 0.0_rp, 0.0_rp)
    call p(2)%set_id(2)
    call p(3)%init(0.0_rp, 1.0_rp, 0.0_rp)
    call p(3)%set_id(4)
    call p(4)%init(1.0_rp, 1.0_rp, 0.0_rp)
    call p(4)%set_id(3)
    call p(5)%init(2.0_rp, 0.0_rp, 0.0_rp)
    call p(5)%set_id(5)
    call p(6)%init(2.0_rp, 1.0_rp, 0.0_rp)
    call p(6)%set_id(6)
    call p(7)%init(0.0_rp, 0.0_rp, 1.0_rp)
    call p(7)%set_id(7)
    call p(8)%init(1.0_rp, 0.0_rp, 1.0_rp)
    call p(8)%set_id(8)
    call p(9)%init(1.0_rp, 1.0_rp, 1.0_rp)
    call p(9)%set_id(9)
    call p(10)%init(0.0_rp, 1.0_rp, 1.0_rp)
    call p(10)%set_id(10)
    call p(11)%init(2.0_rp, 0.0_rp, 1.0_rp)
    call p(11)%set_id(11)
    call p(12)%init(2.0_rp, 1.0_rp, 1.0_rp)
    call p(12)%set_id(12)

    call msh%init(3, 2)
    call msh%add_element(1, 1, p(1), p(2), p(4), p(3), &
         p(7), p(8), p(9), p(10))

    call msh%add_element(2, 2, p(2), p(5), p(6), p(4), &
         p(8), p(11), p(12), p(9))
    call msh%generate_conn()

  end subroutine test_vtkhdf_gen_msh

! #ifdef HAVE_HDF5

  @test(npes=[2])
  subroutine test_vtkhdf_init(this)
    class(test_vtkhdf), intent(inout) :: this
    type(space_t) :: Xh
    type(mesh_t) :: msh
    integer, parameter :: LX = 4
    type(field_t) :: f
    character(len=80) :: fname
    type(file_t) :: file
    integer :: ierr

    fname = "test_init.vtkhdf"
    call file%init(fname)
    @assertTrue(allocated(file%file_type), message="File must be allocated")

    select type(ft => file%file_type)
    class is (vtkhdf_file_t)
       @assertTrue(.true., message="File type must be vtkhdf_file_t")
    class default
       @assertTrue(.false., message="File type must be vtkhdf_file_t")
    end select

    call file%free()
    @assertFalse(allocated(file%file_type), message="File must be deallocated")

  end subroutine test_vtkhdf_init

  @test(npes=[2])
  subroutine test_vtkhdf_write(this)
    class (test_vtkhdf), intent(inout) :: this
    type(space_t) :: Xh
    type(mesh_t) :: msh
    integer, parameter :: LX = 4
    type(field_t) :: f
    character(len=80) :: fname
    type(file_t) :: file
    integer :: ierr
    logical :: exists

    ! HDF5 variables for validation
    integer(hid_t) :: file_id, vtkhdf_grp, attr_id, dset_id
    integer(hid_t) :: filespace, pointdata_grp
    integer(hsize_t), dimension(2) :: h5dims, h5maxdims
    integer :: hdferr, h5rank
    integer :: version_read(2)
    integer :: nop_read(2), noc_read(2), noci_read(2)
    logical :: link_exists
    character(len=16) :: type_read

    ! Expected values: each rank has 2 elements (mesh not distributed), LX=4, 3D:
    ! npts_per_cell = 64, subcells_per_el = 27, nodes_per_cell = 8
    ! local_points = 2*64 = 128, total_points = 256
    ! local_cells = 2*27 = 54, total_cells = 108
    ! local_conn = 54*8 = 432, total_conn = 864
    ! total_offsets = 108 + 2 = 110
    integer, parameter :: EXP_LOCAL_POINTS = 128
    integer, parameter :: EXP_LOCAL_CELLS = 54
    integer, parameter :: EXP_LOCAL_CONN = 432
    integer, parameter :: EXP_TOTAL_POINTS = 256
    integer, parameter :: EXP_TOTAL_CELLS = 108
    integer, parameter :: EXP_TOTAL_CONN = 864
    integer, parameter :: EXP_TOTAL_OFFSETS = 110
    integer, parameter :: EXP_NUM_PARTS = 2

    ! Prepare the environment for the test
    call MPI_Comm_dup(this%getMpiCommunicator(), NEKO_COMM%mpi_val, ierr)
    pe_rank = this%getProcessRank()
    pe_size = this%getNumProcesses()

    ! Create the test mesh and field
    call test_vtkhdf_gen_msh(msh)
    call Xh%init(GLL, lx, lx, lx)
    call f%init(msh, Xh, 'test')
    call field_cfill(f, 1.0_rp)

    ! Remove stale file from previous runs
    fname = "test_write.vtkhdf"
    inquire(file=fname, exist=exists)
    if (exists .and. pe_rank .eq. 0) then
       open(unit=99, file=fname, status='old')
       close(99, status='delete')
    end if
    call MPI_Barrier(NEKO_COMM%mpi_val, ierr)

    ! Perform the write operation
    call file%init(fname)
    call file%write(f)
    call file%free()

    ! Test that the file exists
    inquire(file=fname, exist=exists)
    @assertTrue(exists, message="Output file must exist")

    ! ================================================================
    ! Validate HDF5 file contents
    ! ================================================================
    call h5open_f(hdferr)
    call h5fopen_f(fname, H5F_ACC_RDONLY_F, file_id, hdferr)
    @assertEqual(0, hdferr, message="Must open HDF5 file")

    ! -- VTKHDF group must exist --
    call h5lexists_f(file_id, "VTKHDF", link_exists, hdferr)
    @assertTrue(link_exists, message="VTKHDF group must exist")
    call h5gopen_f(file_id, "VTKHDF", vtkhdf_grp, hdferr)

    ! -- Version attribute --
    call h5aopen_f(vtkhdf_grp, "Version", attr_id, hdferr)
    @assertEqual(0, hdferr, message="Version attribute must exist")
    h5dims(1) = 2
    call h5aread_f(attr_id, H5T_NATIVE_INTEGER, version_read, h5dims(1:1), hdferr)
    @assertEqual(2, version_read(1), message="Version major must be 2")
    @assertEqual(4, version_read(2), message="Version minor must be 4")
    call h5aclose_f(attr_id, hdferr)

    ! -- Type attribute --
    call h5aopen_f(vtkhdf_grp, "Type", attr_id, hdferr)
    @assertEqual(0, hdferr, message="Type attribute must exist")
    call h5aclose_f(attr_id, hdferr)

    ! -- NumberOfPoints dataset: shape (EXP_NUM_PARTS,) --
    call h5lexists_f(vtkhdf_grp, "NumberOfPoints", link_exists, hdferr)
    @assertTrue(link_exists, message="NumberOfPoints must exist")
    call h5dopen_f(vtkhdf_grp, "NumberOfPoints", dset_id, hdferr)
    call h5dget_space_f(dset_id, filespace, hdferr)
    call h5sget_simple_extent_dims_f(filespace, h5dims, h5maxdims, hdferr)
    @assertEqual(EXP_NUM_PARTS, int(h5dims(1)), message="NumberOfPoints size must equal num partitions")
    call h5dread_f(dset_id, H5T_NATIVE_INTEGER, nop_read, h5dims(1:1), hdferr)
    @assertEqual(EXP_LOCAL_POINTS, nop_read(1), message="NumberOfPoints partition 0 must match local")
    @assertEqual(EXP_LOCAL_POINTS, nop_read(2), message="NumberOfPoints partition 1 must match local")
    call h5sclose_f(filespace, hdferr)
    call h5dclose_f(dset_id, hdferr)

    ! -- NumberOfCells dataset: shape (EXP_NUM_PARTS,) --
    call h5lexists_f(vtkhdf_grp, "NumberOfCells", link_exists, hdferr)
    @assertTrue(link_exists, message="NumberOfCells must exist")
    call h5dopen_f(vtkhdf_grp, "NumberOfCells", dset_id, hdferr)
    call h5dget_space_f(dset_id, filespace, hdferr)
    call h5sget_simple_extent_dims_f(filespace, h5dims, h5maxdims, hdferr)
    @assertEqual(EXP_NUM_PARTS, int(h5dims(1)), message="NumberOfCells size must equal num partitions")
    call h5dread_f(dset_id, H5T_NATIVE_INTEGER, noc_read, h5dims(1:1), hdferr)
    @assertEqual(EXP_LOCAL_CELLS, noc_read(1), message="NumberOfCells partition 0 must match local")
    @assertEqual(EXP_LOCAL_CELLS, noc_read(2), message="NumberOfCells partition 1 must match local")
    call h5sclose_f(filespace, hdferr)
    call h5dclose_f(dset_id, hdferr)

    ! -- NumberOfConnectivityIds dataset: shape (EXP_NUM_PARTS,) --
    call h5lexists_f(vtkhdf_grp, "NumberOfConnectivityIds", link_exists, hdferr)
    @assertTrue(link_exists, message="NumberOfConnectivityIds must exist")
    call h5dopen_f(vtkhdf_grp, "NumberOfConnectivityIds", dset_id, hdferr)
    call h5dget_space_f(dset_id, filespace, hdferr)
    call h5sget_simple_extent_dims_f(filespace, h5dims, h5maxdims, hdferr)
    @assertEqual(EXP_NUM_PARTS, int(h5dims(1)), message="NumberOfConnectivityIds size must equal num partitions")
    call h5dread_f(dset_id, H5T_NATIVE_INTEGER, noci_read, h5dims(1:1), hdferr)
    @assertEqual(EXP_LOCAL_CONN, noci_read(1), message="NumberOfConnectivityIds partition 0 must match local")
    @assertEqual(EXP_LOCAL_CONN, noci_read(2), message="NumberOfConnectivityIds partition 1 must match local")
    call h5sclose_f(filespace, hdferr)
    call h5dclose_f(dset_id, hdferr)

    ! -- Points dataset: shape (3, TOTAL_POINTS) --
    call h5lexists_f(vtkhdf_grp, "Points", link_exists, hdferr)
    @assertTrue(link_exists, message="Points dataset must exist")
    call h5dopen_f(vtkhdf_grp, "Points", dset_id, hdferr)
    call h5dget_space_f(dset_id, filespace, hdferr)
    call h5sget_simple_extent_ndims_f(filespace, h5rank, hdferr)
    @assertEqual(2, h5rank, message="Points must be 2D")
    call h5sget_simple_extent_dims_f(filespace, h5dims, h5maxdims, hdferr)
    @assertEqual(3, int(h5dims(1)), message="Points dim 1 must be 3")
    @assertEqual(EXP_TOTAL_POINTS, int(h5dims(2)), message="Points dim 2 must be total points")
    call h5sclose_f(filespace, hdferr)
    call h5dclose_f(dset_id, hdferr)

    ! -- Connectivity dataset: shape (TOTAL_CONN,) --
    call h5lexists_f(vtkhdf_grp, "Connectivity", link_exists, hdferr)
    @assertTrue(link_exists, message="Connectivity dataset must exist")
    call h5dopen_f(vtkhdf_grp, "Connectivity", dset_id, hdferr)
    call h5dget_space_f(dset_id, filespace, hdferr)
    call h5sget_simple_extent_ndims_f(filespace, h5rank, hdferr)
    @assertEqual(1, h5rank, message="Connectivity must be 1D")
    call h5sget_simple_extent_dims_f(filespace, h5dims, h5maxdims, hdferr)
    @assertEqual(EXP_TOTAL_CONN, int(h5dims(1)), message="Connectivity size must be total conn")
    call h5sclose_f(filespace, hdferr)
    call h5dclose_f(dset_id, hdferr)

    ! -- Offsets dataset: shape (TOTAL_OFFSETS,) --
    call h5lexists_f(vtkhdf_grp, "Offsets", link_exists, hdferr)
    @assertTrue(link_exists, message="Offsets dataset must exist")
    call h5dopen_f(vtkhdf_grp, "Offsets", dset_id, hdferr)
    call h5dget_space_f(dset_id, filespace, hdferr)
    call h5sget_simple_extent_ndims_f(filespace, h5rank, hdferr)
    @assertEqual(1, h5rank, message="Offsets must be 1D")
    call h5sget_simple_extent_dims_f(filespace, h5dims, h5maxdims, hdferr)
    @assertEqual(EXP_TOTAL_OFFSETS, int(h5dims(1)), message="Offsets size must be total offsets")
    call h5sclose_f(filespace, hdferr)
    call h5dclose_f(dset_id, hdferr)

    ! -- Types dataset: shape (TOTAL_CELLS,) --
    call h5lexists_f(vtkhdf_grp, "Types", link_exists, hdferr)
    @assertTrue(link_exists, message="Types dataset must exist")
    call h5dopen_f(vtkhdf_grp, "Types", dset_id, hdferr)
    call h5dget_space_f(dset_id, filespace, hdferr)
    call h5sget_simple_extent_ndims_f(filespace, h5rank, hdferr)
    @assertEqual(1, h5rank, message="Types must be 1D")
    call h5sget_simple_extent_dims_f(filespace, h5dims, h5maxdims, hdferr)
    @assertEqual(EXP_TOTAL_CELLS, int(h5dims(1)), message="Types size must be total cells")
    call h5sclose_f(filespace, hdferr)
    call h5dclose_f(dset_id, hdferr)

    ! -- PointData group with 'test' field --
    call h5lexists_f(vtkhdf_grp, "PointData", link_exists, hdferr)
    @assertTrue(link_exists, message="PointData group must exist")
    call h5gopen_f(vtkhdf_grp, "PointData", pointdata_grp, hdferr)

    call h5lexists_f(pointdata_grp, "test", link_exists, hdferr)
    @assertTrue(link_exists, message="PointData/test field must exist")
    call h5dopen_f(pointdata_grp, "test", dset_id, hdferr)
    call h5dget_space_f(dset_id, filespace, hdferr)
    call h5sget_simple_extent_ndims_f(filespace, h5rank, hdferr)
    @assertEqual(1, h5rank, message="test field must be 1D (scalar)")
    call h5sget_simple_extent_dims_f(filespace, h5dims, h5maxdims, hdferr)
    @assertEqual(EXP_TOTAL_POINTS, int(h5dims(1)), message="test field size must be total points")
    call h5sclose_f(filespace, hdferr)
    call h5dclose_f(dset_id, hdferr)

    call h5gclose_f(pointdata_grp, hdferr)

    ! -- No Steps group for non-temporal write --
    call h5lexists_f(vtkhdf_grp, "Steps", link_exists, hdferr)
    @assertFalse(link_exists, message="Steps group must not exist for non-temporal write")

    ! Cleanup
    call h5gclose_f(vtkhdf_grp, hdferr)
    call h5fclose_f(file_id, hdferr)
    call h5close_f(hdferr)


  end subroutine test_vtkhdf_write

  @test(npes=[2])
  subroutine test_vtkhdf_write_time(this)
    class (test_vtkhdf), intent(inout) :: this
    type(space_t) :: Xh
    type(mesh_t) :: msh
    integer, parameter :: LX = 4
    type(field_t) :: f
    character(len=80) :: fname
    type(file_t) :: file
    integer :: ierr
    logical :: exists

    ! HDF5 variables for validation
    integer(hid_t) :: file_id, vtkhdf_grp, attr_id, dset_id
    integer(hid_t) :: filespace, pointdata_grp, steps_grp, pdo_grp
    integer(hsize_t), dimension(2) :: h5dims, h5maxdims
    integer :: hdferr, h5rank
    integer :: version_read(2)
    integer :: nop_read(2), noc_read(2), noci_read(2)
    integer :: nsteps_read(1)
    integer :: nparts_read(2), partoffs_read(2)
    integer :: ptoffs_read(2), celloffs_read(2)
    integer :: connoffs_read(2), pdoffs_read(2)
    real(rp) :: values_read(2)
    logical :: link_exists

    ! Expected values: same geometry as non-temporal, 2 timesteps
    integer, parameter :: EXP_LOCAL_POINTS = 128
    integer, parameter :: EXP_LOCAL_CELLS = 54
    integer, parameter :: EXP_LOCAL_CONN = 432
    integer, parameter :: EXP_TOTAL_POINTS = 256
    integer, parameter :: EXP_TOTAL_CELLS = 108
    integer, parameter :: EXP_TOTAL_CONN = 864
    integer, parameter :: EXP_TOTAL_OFFSETS = 110
    integer, parameter :: EXP_NUM_PARTS = 2
    integer, parameter :: EXP_NUM_STEPS = 2

    ! Prepare the environment for the test
    call MPI_Comm_dup(this%getMpiCommunicator(), NEKO_COMM%mpi_val, ierr)
    pe_rank = this%getProcessRank()
    pe_size = this%getNumProcesses()

    ! Create the test mesh and field
    call test_vtkhdf_gen_msh(msh)
    call Xh%init(GLL, lx, lx, lx)
    call f%init(msh, Xh, 'test')
    call field_cfill(f, 1.0_rp)

    ! Remove stale file from previous runs
    fname = "test_write_time.vtkhdf"
    inquire(file=fname, exist=exists)
    if (exists .and. pe_rank .eq. 0) then
       open(unit=99, file=fname, status='old')
       close(99, status='delete')
    end if
    call MPI_Barrier(NEKO_COMM%mpi_val, ierr)

    ! Perform the write operation: 2 timesteps at t=0.0 and t=1.0
    call file%init(fname)
    call file%write(f, 0.0_rp)
    call field_cfill(f, 2.0_rp)
    call file%write(f, 1.0_rp)
    call file%free()

    ! Test that the file exists
    inquire(file=fname, exist=exists)
    @assertTrue(exists, message="Temporal output file must exist")

    ! ================================================================
    ! Validate HDF5 file contents
    ! ================================================================
    call h5open_f(hdferr)
    call h5fopen_f(fname, H5F_ACC_RDONLY_F, file_id, hdferr)
    @assertEqual(0, hdferr, message="Must open temporal HDF5 file")

    ! -- VTKHDF group --
    call h5lexists_f(file_id, "VTKHDF", link_exists, hdferr)
    @assertTrue(link_exists, message="VTKHDF group must exist (temporal)")
    call h5gopen_f(file_id, "VTKHDF", vtkhdf_grp, hdferr)

    ! -- Version attribute --
    call h5aopen_f(vtkhdf_grp, "Version", attr_id, hdferr)
    @assertEqual(0, hdferr, message="Version attribute must exist (temporal)")
    h5dims(1) = 2
    call h5aread_f(attr_id, H5T_NATIVE_INTEGER, version_read, h5dims(1:1), hdferr)
    @assertEqual(2, version_read(1), message="Version major must be 2 (temporal)")
    @assertEqual(4, version_read(2), message="Version minor must be 4 (temporal)")
    call h5aclose_f(attr_id, hdferr)

    ! -- Type attribute --
    call h5aopen_f(vtkhdf_grp, "Type", attr_id, hdferr)
    @assertEqual(0, hdferr, message="Type attribute must exist (temporal)")
    call h5aclose_f(attr_id, hdferr)

    ! -- NumberOfPoints dataset --
    call h5lexists_f(vtkhdf_grp, "NumberOfPoints", link_exists, hdferr)
    @assertTrue(link_exists, message="NumberOfPoints must exist (temporal)")
    call h5dopen_f(vtkhdf_grp, "NumberOfPoints", dset_id, hdferr)
    call h5dget_space_f(dset_id, filespace, hdferr)
    call h5sget_simple_extent_dims_f(filespace, h5dims, h5maxdims, hdferr)
    @assertEqual(EXP_NUM_PARTS, int(h5dims(1)), message="NumberOfPoints size (temporal)")
    call h5dread_f(dset_id, H5T_NATIVE_INTEGER, nop_read, h5dims(1:1), hdferr)
    @assertEqual(EXP_LOCAL_POINTS, nop_read(1), message="NumberOfPoints part 0 (temporal)")
    @assertEqual(EXP_LOCAL_POINTS, nop_read(2), message="NumberOfPoints part 1 (temporal)")
    call h5sclose_f(filespace, hdferr)
    call h5dclose_f(dset_id, hdferr)

    ! -- NumberOfCells dataset --
    call h5lexists_f(vtkhdf_grp, "NumberOfCells", link_exists, hdferr)
    @assertTrue(link_exists, message="NumberOfCells must exist (temporal)")
    call h5dopen_f(vtkhdf_grp, "NumberOfCells", dset_id, hdferr)
    call h5dget_space_f(dset_id, filespace, hdferr)
    call h5sget_simple_extent_dims_f(filespace, h5dims, h5maxdims, hdferr)
    @assertEqual(EXP_NUM_PARTS, int(h5dims(1)), message="NumberOfCells size (temporal)")
    call h5dread_f(dset_id, H5T_NATIVE_INTEGER, noc_read, h5dims(1:1), hdferr)
    @assertEqual(EXP_LOCAL_CELLS, noc_read(1), message="NumberOfCells part 0 (temporal)")
    @assertEqual(EXP_LOCAL_CELLS, noc_read(2), message="NumberOfCells part 1 (temporal)")
    call h5sclose_f(filespace, hdferr)
    call h5dclose_f(dset_id, hdferr)

    ! -- NumberOfConnectivityIds dataset --
    call h5lexists_f(vtkhdf_grp, "NumberOfConnectivityIds", link_exists, hdferr)
    @assertTrue(link_exists, message="NumberOfConnectivityIds must exist (temporal)")
    call h5dopen_f(vtkhdf_grp, "NumberOfConnectivityIds", dset_id, hdferr)
    call h5dget_space_f(dset_id, filespace, hdferr)
    call h5sget_simple_extent_dims_f(filespace, h5dims, h5maxdims, hdferr)
    @assertEqual(EXP_NUM_PARTS, int(h5dims(1)), message="NumberOfConnectivityIds size (temporal)")
    call h5dread_f(dset_id, H5T_NATIVE_INTEGER, noci_read, h5dims(1:1), hdferr)
    @assertEqual(EXP_LOCAL_CONN, noci_read(1), message="NumberOfConnectivityIds part 0 (temporal)")
    @assertEqual(EXP_LOCAL_CONN, noci_read(2), message="NumberOfConnectivityIds part 1 (temporal)")
    call h5sclose_f(filespace, hdferr)
    call h5dclose_f(dset_id, hdferr)

    ! -- Points dataset: static mesh, shape (TOTAL_POINTS, 3) --
    call h5lexists_f(vtkhdf_grp, "Points", link_exists, hdferr)
    @assertTrue(link_exists, message="Points must exist (temporal)")
    call h5dopen_f(vtkhdf_grp, "Points", dset_id, hdferr)
    call h5dget_space_f(dset_id, filespace, hdferr)
    call h5sget_simple_extent_ndims_f(filespace, h5rank, hdferr)
    @assertEqual(2, h5rank, message="Points must be 2D (temporal)")
    call h5sget_simple_extent_dims_f(filespace, h5dims, h5maxdims, hdferr)
    @assertEqual(3, int(h5dims(1)), message="Points dim 1 must be 3 (temporal)")
    @assertEqual(EXP_TOTAL_POINTS, int(h5dims(2)), message="Points dim 2 (temporal)")
    call h5sclose_f(filespace, hdferr)
    call h5dclose_f(dset_id, hdferr)

    ! -- Connectivity dataset --
    call h5lexists_f(vtkhdf_grp, "Connectivity", link_exists, hdferr)
    @assertTrue(link_exists, message="Connectivity must exist (temporal)")
    call h5dopen_f(vtkhdf_grp, "Connectivity", dset_id, hdferr)
    call h5dget_space_f(dset_id, filespace, hdferr)
    call h5sget_simple_extent_ndims_f(filespace, h5rank, hdferr)
    @assertEqual(1, h5rank, message="Connectivity must be 1D (temporal)")
    call h5sget_simple_extent_dims_f(filespace, h5dims, h5maxdims, hdferr)
    @assertEqual(EXP_TOTAL_CONN, int(h5dims(1)), message="Connectivity size (temporal)")
    call h5sclose_f(filespace, hdferr)
    call h5dclose_f(dset_id, hdferr)

    ! -- Offsets dataset --
    call h5lexists_f(vtkhdf_grp, "Offsets", link_exists, hdferr)
    @assertTrue(link_exists, message="Offsets must exist (temporal)")
    call h5dopen_f(vtkhdf_grp, "Offsets", dset_id, hdferr)
    call h5dget_space_f(dset_id, filespace, hdferr)
    call h5sget_simple_extent_ndims_f(filespace, h5rank, hdferr)
    @assertEqual(1, h5rank, message="Offsets must be 1D (temporal)")
    call h5sget_simple_extent_dims_f(filespace, h5dims, h5maxdims, hdferr)
    @assertEqual(EXP_TOTAL_OFFSETS, int(h5dims(1)), message="Offsets size (temporal)")
    call h5sclose_f(filespace, hdferr)
    call h5dclose_f(dset_id, hdferr)

    ! -- Types dataset --
    call h5lexists_f(vtkhdf_grp, "Types", link_exists, hdferr)
    @assertTrue(link_exists, message="Types must exist (temporal)")
    call h5dopen_f(vtkhdf_grp, "Types", dset_id, hdferr)
    call h5dget_space_f(dset_id, filespace, hdferr)
    call h5sget_simple_extent_ndims_f(filespace, h5rank, hdferr)
    @assertEqual(1, h5rank, message="Types must be 1D (temporal)")
    call h5sget_simple_extent_dims_f(filespace, h5dims, h5maxdims, hdferr)
    @assertEqual(EXP_TOTAL_CELLS, int(h5dims(1)), message="Types size (temporal)")
    call h5sclose_f(filespace, hdferr)
    call h5dclose_f(dset_id, hdferr)

    ! -- PointData/test: 2 timesteps, shape (TOTAL_POINTS * NUM_STEPS) --
    call h5lexists_f(vtkhdf_grp, "PointData", link_exists, hdferr)
    @assertTrue(link_exists, message="PointData must exist (temporal)")
    call h5gopen_f(vtkhdf_grp, "PointData", pointdata_grp, hdferr)
    call h5lexists_f(pointdata_grp, "test", link_exists, hdferr)
    @assertTrue(link_exists, message="PointData/test must exist (temporal)")
    call h5dopen_f(pointdata_grp, "test", dset_id, hdferr)
    call h5dget_space_f(dset_id, filespace, hdferr)
    call h5sget_simple_extent_ndims_f(filespace, h5rank, hdferr)
    @assertEqual(1, h5rank, message="test field must be 1D (temporal)")
    call h5sget_simple_extent_dims_f(filespace, h5dims, h5maxdims, hdferr)
    @assertEqual(EXP_TOTAL_POINTS * EXP_NUM_STEPS, int(h5dims(1)), message="test field size (temporal)")
    call h5sclose_f(filespace, hdferr)
    call h5dclose_f(dset_id, hdferr)
    call h5gclose_f(pointdata_grp, hdferr)

    ! ================================================================
    ! Validate Steps group
    ! ================================================================
    call h5lexists_f(vtkhdf_grp, "Steps", link_exists, hdferr)
    @assertTrue(link_exists, message="Steps group must exist for temporal write")
    call h5gopen_f(vtkhdf_grp, "Steps", steps_grp, hdferr)

    ! -- NSteps attribute --
    call h5aopen_f(steps_grp, "NSteps", attr_id, hdferr)
    @assertEqual(0, hdferr, message="NSteps attribute must exist")
    h5dims(1) = 1
    call h5aread_f(attr_id, H5T_NATIVE_INTEGER, nsteps_read, h5dims(1:1), hdferr)
    @assertEqual(EXP_NUM_STEPS, nsteps_read(1), message="NSteps must be 2")
    call h5aclose_f(attr_id, hdferr)

    ! -- Values dataset: shape (NUM_STEPS,) with [0.0, 1.0] --
    call h5lexists_f(steps_grp, "Values", link_exists, hdferr)
    @assertTrue(link_exists, message="Steps/Values must exist")
    call h5dopen_f(steps_grp, "Values", dset_id, hdferr)
    call h5dget_space_f(dset_id, filespace, hdferr)
    call h5sget_simple_extent_dims_f(filespace, h5dims, h5maxdims, hdferr)
    @assertEqual(EXP_NUM_STEPS, int(h5dims(1)), message="Values size must be num steps")
    call h5dread_f(dset_id, H5T_NATIVE_DOUBLE, values_read, h5dims(1:1), hdferr)
    @assertEqual(0.0_rp, values_read(1), message="Values(1) must be 0.0")
    @assertEqual(1.0_rp, values_read(2), message="Values(2) must be 1.0")
    call h5sclose_f(filespace, hdferr)
    call h5dclose_f(dset_id, hdferr)

    ! -- NumberOfParts dataset: shape (NUM_STEPS,) with [2, 2] --
    call h5lexists_f(steps_grp, "NumberOfParts", link_exists, hdferr)
    @assertTrue(link_exists, message="Steps/NumberOfParts must exist")
    call h5dopen_f(steps_grp, "NumberOfParts", dset_id, hdferr)
    call h5dget_space_f(dset_id, filespace, hdferr)
    call h5sget_simple_extent_dims_f(filespace, h5dims, h5maxdims, hdferr)
    @assertEqual(EXP_NUM_STEPS, int(h5dims(1)), message="NumberOfParts size must be num steps")
    call h5dread_f(dset_id, H5T_NATIVE_INTEGER, nparts_read, h5dims(1:1), hdferr)
    @assertEqual(EXP_NUM_PARTS, nparts_read(1), message="NumberOfParts(1) must be 2")
    @assertEqual(EXP_NUM_PARTS, nparts_read(2), message="NumberOfParts(2) must be 2")
    call h5sclose_f(filespace, hdferr)
    call h5dclose_f(dset_id, hdferr)

    ! -- PartOffsets dataset: shape (NUM_STEPS,) with [0, 0] (static mesh) --
    call h5lexists_f(steps_grp, "PartOffsets", link_exists, hdferr)
    @assertTrue(link_exists, message="Steps/PartOffsets must exist")
    call h5dopen_f(steps_grp, "PartOffsets", dset_id, hdferr)
    call h5dget_space_f(dset_id, filespace, hdferr)
    call h5sget_simple_extent_dims_f(filespace, h5dims, h5maxdims, hdferr)
    @assertEqual(EXP_NUM_STEPS, int(h5dims(1)), message="PartOffsets size must be num steps")
    call h5dread_f(dset_id, H5T_NATIVE_INTEGER, partoffs_read, h5dims(1:1), hdferr)
    @assertEqual(0, partoffs_read(1), message="PartOffsets(1) must be 0")
    @assertEqual(0, partoffs_read(2), message="PartOffsets(2) must be 0")
    call h5sclose_f(filespace, hdferr)
    call h5dclose_f(dset_id, hdferr)

    ! -- PointOffsets dataset: shape (NUM_STEPS,) with [0, 0] (static mesh) --
    call h5lexists_f(steps_grp, "PointOffsets", link_exists, hdferr)
    @assertTrue(link_exists, message="Steps/PointOffsets must exist")
    call h5dopen_f(steps_grp, "PointOffsets", dset_id, hdferr)
    call h5dget_space_f(dset_id, filespace, hdferr)
    call h5sget_simple_extent_dims_f(filespace, h5dims, h5maxdims, hdferr)
    @assertEqual(EXP_NUM_STEPS, int(h5dims(1)), message="PointOffsets size must be num steps")
    call h5dread_f(dset_id, H5T_NATIVE_INTEGER, ptoffs_read, h5dims(1:1), hdferr)
    @assertEqual(0, ptoffs_read(1), message="PointOffsets(1) must be 0")
    @assertEqual(0, ptoffs_read(2), message="PointOffsets(2) must be 0")
    call h5sclose_f(filespace, hdferr)
    call h5dclose_f(dset_id, hdferr)

    ! -- CellOffsets dataset: shape (NUM_STEPS,) with [0, 0] (static mesh) --
    call h5lexists_f(steps_grp, "CellOffsets", link_exists, hdferr)
    @assertTrue(link_exists, message="Steps/CellOffsets must exist")
    call h5dopen_f(steps_grp, "CellOffsets", dset_id, hdferr)
    call h5dget_space_f(dset_id, filespace, hdferr)
    call h5sget_simple_extent_dims_f(filespace, h5dims, h5maxdims, hdferr)
    @assertEqual(EXP_NUM_STEPS, int(h5dims(1)), message="CellOffsets size must be num steps")
    call h5dread_f(dset_id, H5T_NATIVE_INTEGER, celloffs_read, h5dims(1:1), hdferr)
    @assertEqual(0, celloffs_read(1), message="CellOffsets(1) must be 0")
    @assertEqual(0, celloffs_read(2), message="CellOffsets(2) must be 0")
    call h5sclose_f(filespace, hdferr)
    call h5dclose_f(dset_id, hdferr)

    ! -- ConnectivityIdOffsets: shape (NUM_STEPS,) with [0, 0] (static mesh) --
    call h5lexists_f(steps_grp, "ConnectivityIdOffsets", link_exists, hdferr)
    @assertTrue(link_exists, message="Steps/ConnectivityIdOffsets must exist")
    call h5dopen_f(steps_grp, "ConnectivityIdOffsets", dset_id, hdferr)
    call h5dget_space_f(dset_id, filespace, hdferr)
    call h5sget_simple_extent_dims_f(filespace, h5dims, h5maxdims, hdferr)
    @assertEqual(EXP_NUM_STEPS, int(h5dims(1)), message="ConnectivityIdOffsets size must be num steps")
    call h5dread_f(dset_id, H5T_NATIVE_INTEGER, connoffs_read, h5dims(1:1), hdferr)
    @assertEqual(0, connoffs_read(1), message="ConnectivityIdOffsets(1) must be 0")
    @assertEqual(0, connoffs_read(2), message="ConnectivityIdOffsets(2) must be 0")
    call h5sclose_f(filespace, hdferr)
    call h5dclose_f(dset_id, hdferr)

    ! -- PointDataOffsets/test: shape (NUM_STEPS,) with [0, TOTAL_POINTS] --
    call h5lexists_f(steps_grp, "PointDataOffsets", link_exists, hdferr)
    @assertTrue(link_exists, message="Steps/PointDataOffsets must exist")
    call h5gopen_f(steps_grp, "PointDataOffsets", pdo_grp, hdferr)
    call h5lexists_f(pdo_grp, "test", link_exists, hdferr)
    @assertTrue(link_exists, message="PointDataOffsets/test must exist")
    call h5dopen_f(pdo_grp, "test", dset_id, hdferr)
    call h5dget_space_f(dset_id, filespace, hdferr)
    call h5sget_simple_extent_dims_f(filespace, h5dims, h5maxdims, hdferr)
    @assertEqual(EXP_NUM_STEPS, int(h5dims(1)), message="PointDataOffsets/test size must be num steps")
    call h5dread_f(dset_id, H5T_NATIVE_INTEGER, pdoffs_read, h5dims(1:1), hdferr)
    @assertEqual(0, pdoffs_read(1), message="PointDataOffsets/test(1) must be 0")
    @assertEqual(EXP_TOTAL_POINTS, pdoffs_read(2), message="PointDataOffsets/test(2) must be total_points")
    call h5sclose_f(filespace, hdferr)
    call h5dclose_f(dset_id, hdferr)
    call h5gclose_f(pdo_grp, hdferr)

    ! Cleanup Steps group
    call h5gclose_f(steps_grp, hdferr)

    ! Cleanup
    call h5gclose_f(vtkhdf_grp, hdferr)
    call h5fclose_f(file_id, hdferr)
    call h5close_f(hdferr)

  end subroutine test_vtkhdf_write_time


! #else
!   subroutine test_vtkhdf_init(this)
!     class(test_vtkhdf), intent(inout) :: this
!     @assertTrue(.true., message="HDF5 support is not available, skipping test")
!   end subroutine test_vtkhdf_init
!   subroutine test_vtkhdf_write(this)
!     class (test_vtkhdf), intent(inout) :: this
!     @assertTrue(.true., message="HDF5 support is not available, skipping test")
!   end subroutine test_vtkhdf_write
!   subroutine test_vtkhdf_write_time(this)
!     class (test_vtkhdf), intent(inout) :: this
!     @assertTrue(.true., message="HDF5 support is not available, skipping test")
!   end subroutine test_vtkhdf_write_time
! #endif

end module vtkhdf_parallel
