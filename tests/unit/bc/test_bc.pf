module test_bc
  use pfunit
  use device, only : device_init, device_finalize
  use neko_config, only : NEKO_BCKND_DEVICE
  implicit none

  @TestCase
  type, extends(TestCase) :: test_bc_case
   contains
     procedure :: setUp
     procedure :: tearDown
  end type test_bc_case

contains

  subroutine setUp(this)
    class(test_bc_case), intent(inout) :: this
    if (NEKO_BCKND_DEVICE .eq. 1) then
       call device_init
    end if
  end subroutine setUp

  subroutine tearDown(this)
    class(test_bc_case), intent(inout) :: this
    if (NEKO_BCKND_DEVICE .eq. 1) then
       call device_finalize
    end if
  end subroutine tearDown

! @test
! subroutine test_bc_init
!   use pfunit
!   use dofmap
!   use bc   
!   implicit none
!   type(bc_t) :: b
!   type(dofmap_t) :: dof

!   call b%init(dof)

!   @assertTrue(associated(b%dof))
!   @assertTrue(associated(b%msh))
!   @assertTrue(associated(b%Xh))
! end subroutine test_bc_init



end module test_bc
