module test_stack_i4r8t2
  use pfunit
  use device, only : device_init, device_finalize
  use neko_config, only : NEKO_BCKND_DEVICE
  implicit none

  @TestCase
  type, extends(TestCase) :: test_stack_i4r8t2_case
   contains
     procedure :: setUp
     procedure :: tearDown
  end type test_stack_i4r8t2_case

contains

  subroutine setUp(this)
    class(test_stack_i4r8t2_case), intent(inout) :: this
    if (NEKO_BCKND_DEVICE .eq. 1) then
       call device_init
    end if
  end subroutine setUp

  subroutine tearDown(this)
    class(test_stack_i4r8t2_case), intent(inout) :: this
    if (NEKO_BCKND_DEVICE .eq. 1) then
       call device_finalize
    end if
  end subroutine tearDown

@test
subroutine test_stack_i4r8t2_init(this)
  use pfunit
  use stack
  use math, only : NEKO_M_LN2
  use num_types, only :rp
  class(test_stack_i4r8t2_case), intent(inout) :: this
  type(stack_i4r8t2_t) :: s1, s2, s3
  integer, parameter :: size_t = ishft(1, ceiling(log(real(32, rp)) / NEKO_M_LN2))

  call s1%init()
  @assertTrue(allocated(s1%data))
  @assertEqual(s1%size_, size_t)
  @assertEqual(size(s1%array()), size_t)
  @assertEqual(s1%size_, size(s1%array()))
  @assertEqual(s1%top_, s1%size())
  @assertTrue(s1%is_empty())
  @assertLessThan(s1%size(), size(s1%array()))

  call s2%init(10)
  @assertTrue(allocated(s2%data))
  @assertEqual(s2%size_, 16)
  @assertEqual(size(s2%array()), 16)
  @assertEqual(s2%size_, size(s2%array()))
  @assertEqual(s2%top_, s2%size())
  @assertTrue(s2%is_empty())
  @assertLessThan(s2%size(), size(s2%array()))

  call s3%init(0)
  @assertTrue(allocated(s3%data))
  @assertEqual(s3%size_, size_t)
  @assertEqual(size(s3%array()), size_t)
  @assertEqual(s3%size_, size(s3%array()))
  @assertEqual(s3%top_, s3%size())
  @assertTrue(s3%is_empty())
  @assertLessThan(s3%size(), size(s3%array()))

end subroutine test_stack_i4r8t2_init

@test
subroutine test_stack_i4r8t2_free(this)
  use pfunit
  use stack
  class(test_stack_i4r8t2_case), intent(inout) :: this
  type(stack_i4r8t2_t) :: s

  call s%init()
  call s%free()
  @assertFalse(allocated(s%data))
  @assertEqual(s%size_, 0)
  @assertEqual(s%top_, 0)
  @assertEqual(s%size(), 0)
  @assertTrue(s%is_empty())
  
end subroutine test_stack_i4r8t2_free

@test
subroutine test_stack_i4r8t2_push(this)
  use pfunit
  use stack
  use tuple
  class(test_stack_i4r8t2_case), intent(inout) :: this
  type(stack_i4r8t2_t) :: s
  integer :: i
  type(tuple_i4r8_t) :: data
  type(tuple_i4r8_t), pointer :: dp(:)

  call s%init()  
  do i = 1, 64
     data = (/i , -i/)
     call s%push(data)
  end do
  ! Pushing data should make the stack non-empty without reallocating early.
  @assertEqual(s%size_, 64, message='Unnecessary reallocation')
  @assertEqual(s%top_, s%size_, message='Corrupt size')
  @assertFalse(s%is_empty())

  do i = 1, 2
     data = (/i + 64, -(i + 64)/)
     call s%push(data)
  end do
  ! Crossing the initial capacity should resize once and preserve order.
  @assertEqual(s%size_, 128, message='Unnecessary reallocation')
  @assertEqual(s%top_, (64 + 2), message='Corrupt size')

  dp => s%array()
  do i = 1, 66
     data = (/i, -i/)
     @assertTrue(dp(i) .eq. data)
  end do
 
end subroutine test_stack_i4r8t2_push

@test
subroutine test_stack_i4r8t2_pop(this)
  use pfunit
  use stack
  use tuple
  class(test_stack_i4r8t2_case), intent(inout) :: this
  type(stack_i4r8t2_t) :: s
  integer :: i
  type(tuple_i4r8_t) :: data

  call s%init()
  do i = 1, 66
     data = (/i, -i/)
     call s%push(data)
  end do

  do i = 66, 1, -1
     data = (/i, -i/)
     @assertTrue(s%pop() .eq. data)
  end do

  ! Popping all entries should restore the empty-state markers.
  @assertEqual(s%top_, 0, message='Leftover data')
  @assertEqual(s%size_, 128, message='Corrupt size')
  @assertTrue(s%is_empty())
  
end subroutine test_stack_i4r8t2_pop

@test 
subroutine test_stack_i4r8t2_clear(this)
  use pfunit
  use stack
  use tuple
  class(test_stack_i4r8t2_case), intent(inout) :: this
  type(stack_i4r8t2_t) :: s
  integer :: i
  type(tuple_i4r8_t) :: data

  call s%init()
  do i = 1, 66
     data = (/i, -i/)
     call s%push(data)
  end do
  call s%clear()
  ! Clearing should drop the logical contents without shrinking storage.
  @assertEqual(s%size(), s%top_)
  @assertEqual(s%top_, 0, message='Corrupt top marker')
  @assertTrue(s%is_empty())

end subroutine test_stack_i4r8t2_clear

end module test_stack_i4r8t2
