module test_stack_nz
contains
@test
subroutine test_stack_nz_init
  use pfunit
  use stack
  use math, only : NEKO_M_LN2
  use num_types, only : rp
  implicit none
  type(stack_nz_t) :: s1, s2, s3
  integer, parameter :: size_t = ishft(1, ceiling(log(real(32, rp)) / NEKO_M_LN2))

  call s1%init()
  @assertTrue(allocated(s1%data))
  @assertEqual(s1%size_, size_t)
  @assertEqual(size(s1%array()), size_t)
  @assertEqual(s1%size_, size(s1%array()))
  @assertEqual(s1%top_, s1%size())
  @assertTrue(s1%is_empty())
  @assertLessThan(s1%size(), size(s1%array()))

  call s2%init(10)
  @assertTrue(allocated(s2%data))
  @assertEqual(s2%size_, 16)
  @assertEqual(size(s2%array()), 16)
  @assertEqual(s2%size_, size(s2%array()))
  @assertEqual(s2%top_, s2%size())
  @assertTrue(s2%is_empty())
  @assertLessThan(s2%size(), size(s2%array()))

  call s3%init(0)
  @assertTrue(allocated(s3%data))
  @assertEqual(s3%size_, size_t)
  @assertEqual(size(s3%array()), size_t)
  @assertEqual(s3%size_, size(s3%array()))
  @assertEqual(s3%top_, s3%size())
  @assertTrue(s3%is_empty())
  @assertLessThan(s3%size(), size(s3%array()))

end subroutine test_stack_nz_init

@test
subroutine test_stack_nz_free
  use pfunit
  use stack
  implicit none
  type(stack_nz_t) :: s

  call s%init()
  call s%free()
  @assertFalse(allocated(s%data))
  @assertEqual(s%size_, 0)
  @assertEqual(s%top_, 0)
  @assertEqual(s%size(), 0)
  @assertTrue(s%is_empty())

end subroutine test_stack_nz_free

@test
subroutine test_stack_nz_push
  use pfunit
  use stack
  use nmsh
  implicit none
  type(stack_nz_t) :: s
  integer :: i
  type(nmsh_zone_t) :: data
  type(nmsh_zone_t), pointer :: zone_ptr(:)

  call s%init()
  do i = 1, 64
     data%e = i
     data%f = i + 1
     data%p_e = i + 2
     data%p_f = i + 3
     data%glb_pt_ids = (/i, i + 1, i + 2, i + 3/)
     data%type = modulo(i, 4)
     call s%push(data)
  end do
  ! Pushing data should make the stack non-empty without reallocating early.
  @assertEqual(s%size_, 64, message='Unnecessary reallocation')
  @assertEqual(s%top_, s%size_, message='Corrupt size')
  @assertFalse(s%is_empty())

  do i = 1, 2
     data%e = i + 64
     data%f = i + 65
     data%p_e = i + 66
     data%p_f = i + 67
     data%glb_pt_ids = (/i + 64, i + 65, i + 66, i + 67/)
     data%type = modulo(i + 64, 4)
     call s%push(data)
  end do
  ! Crossing the initial capacity should resize once and preserve order.
  @assertEqual(s%size_, 128, message='Unnecessary reallocation')
  @assertEqual(s%top_, 66, message='Corrupt size')

  zone_ptr => s%array()
  do i = 1, 66
     @assertEqual(zone_ptr(i)%e, i)
     @assertEqual(zone_ptr(i)%f, i + 1)
     @assertEqual(zone_ptr(i)%p_e, i + 2)
     @assertEqual(zone_ptr(i)%p_f, i + 3)
     @assertEqual(zone_ptr(i)%glb_pt_ids, (/i, i + 1, i + 2, i + 3/))
     @assertEqual(zone_ptr(i)%type, modulo(i, 4))
  end do

end subroutine test_stack_nz_push

@test
subroutine test_stack_nz_pop
  use pfunit
  use stack
  use nmsh
  implicit none
  type(stack_nz_t) :: s
  integer :: i
  type(nmsh_zone_t) :: data

  call s%init()
  do i = 1, 66
     data%e = i
     data%f = i + 1
     data%p_e = i + 2
     data%p_f = i + 3
     data%glb_pt_ids = (/i, i + 1, i + 2, i + 3/)
     data%type = modulo(i, 4)
     call s%push(data)
  end do

  do i = 66, 1, -1
     data = s%pop()
     @assertEqual(data%e, i)
     @assertEqual(data%f, i + 1)
     @assertEqual(data%p_e, i + 2)
     @assertEqual(data%p_f, i + 3)
     @assertEqual(data%glb_pt_ids, (/i, i + 1, i + 2, i + 3/))
     @assertEqual(data%type, modulo(i, 4))
  end do

  ! Popping all entries should restore the empty-state markers.
  @assertEqual(s%top_, 0, message='Leftover data')
  @assertEqual(s%size_, 128, message='Corrupt size')
  @assertTrue(s%is_empty())

end subroutine test_stack_nz_pop

@test
subroutine test_stack_nz_clear
  use pfunit
  use stack
  use nmsh
  implicit none
  type(stack_nz_t) :: s
  integer :: i
  type(nmsh_zone_t) :: data

  call s%init()
  do i = 1, 66
     data%e = i
     call s%push(data)
  end do
  call s%clear()
  ! Clearing should drop the logical contents without shrinking storage.
  @assertEqual(s%size(), s%top_)
  @assertEqual(s%top_, 0, message='Corrupt top marker')
  @assertTrue(s%is_empty())

end subroutine test_stack_nz_clear

end module test_stack_nz
