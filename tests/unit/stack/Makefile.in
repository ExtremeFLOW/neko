ifneq ("$(wildcard @PFUNIT_DIR@/include/PFUNIT.mk)", "")
include @PFUNIT_DIR@/include/PFUNIT.mk
endif
FFLAGS += $(PFUNIT_EXTRA_FFLAGS) @NEKO_PKG_FCFLAGS@ -I@top_builddir@/src
FC = @FC@

%.o : %.F90
	$(FC) -c $(FFLAGS) $<


check: stack_test


stack_test_TESTS := test_stack_i4.pf\
		    test_stack_i8.pf\
		    test_stack_r8.pf\
		    test_stack_i4t2.pf\
		    test_stack_i4t4.pf\
		    test_stack_i4r8t2.pf\
		    test_stack_2i4r8t3.pf\
		    test_stack_curve.pf\
		    test_stack_nq.pf\
		    test_stack_nh.pf\
		    test_stack_nz.pf\
		    test_stack_nc.pf\
		    test_stack_pt.pf
stack_test_OTHER_LIBRARIES = -L@top_builddir@/src/.libs -lneko @LDFLAGS@ @LIBS@
$(eval $(call make_pfunit_test,stack_test))
stack_test.inc: Makefile

distclean:
clean:
	$(RM) *.o *.mod *.a  *.inc *.F90 stack_test



all:
html:
install:
distdir:
