module test_stack_nc
  use pfunit
  use device, only : device_init, device_finalize
  use neko_config, only : NEKO_BCKND_DEVICE
  implicit none

  @TestCase
  type, extends(TestCase) :: test_stack_nc_case
   contains
     procedure :: setUp
     procedure :: tearDown
  end type test_stack_nc_case

contains

  subroutine setUp(this)
    class(test_stack_nc_case), intent(inout) :: this
    if (NEKO_BCKND_DEVICE .eq. 1) then
       call device_init
    end if
  end subroutine setUp

  subroutine tearDown(this)
    class(test_stack_nc_case), intent(inout) :: this
    if (NEKO_BCKND_DEVICE .eq. 1) then
       call device_finalize
    end if
  end subroutine tearDown

@test
subroutine test_stack_nc_init(this)
  use pfunit
  use stack
  use math, only : NEKO_M_LN2
  use num_types, only : rp
  implicit none
  class(test_stack_nc_case), intent(inout) :: this
  type(stack_nc_t) :: s1, s2, s3
  integer, parameter :: size_t = ishft(1, ceiling(log(real(32, rp)) / NEKO_M_LN2))

  call s1%init()
  @assertTrue(allocated(s1%data))
  @assertEqual(s1%size_, size_t)
  @assertEqual(size(s1%array()), size_t)
  @assertEqual(s1%size_, size(s1%array()))
  @assertEqual(s1%top_, s1%size())
  @assertTrue(s1%is_empty())
  @assertLessThan(s1%size(), size(s1%array()))

  call s2%init(10)
  @assertTrue(allocated(s2%data))
  @assertEqual(s2%size_, 16)
  @assertEqual(size(s2%array()), 16)
  @assertEqual(s2%size_, size(s2%array()))
  @assertEqual(s2%top_, s2%size())
  @assertTrue(s2%is_empty())
  @assertLessThan(s2%size(), size(s2%array()))

  call s3%init(0)
  @assertTrue(allocated(s3%data))
  @assertEqual(s3%size_, size_t)
  @assertEqual(size(s3%array()), size_t)
  @assertEqual(s3%size_, size(s3%array()))
  @assertEqual(s3%top_, s3%size())
  @assertTrue(s3%is_empty())
  @assertLessThan(s3%size(), size(s3%array()))

end subroutine test_stack_nc_init

@test
subroutine test_stack_nc_free(this)
  use pfunit
  use stack
  implicit none
  class(test_stack_nc_case), intent(inout) :: this
  type(stack_nc_t) :: s

  call s%init()
  call s%free()
  @assertFalse(allocated(s%data))
  @assertEqual(s%size_, 0)
  @assertEqual(s%top_, 0)
  @assertEqual(s%size(), 0)
  @assertTrue(s%is_empty())

end subroutine test_stack_nc_free

@test
subroutine test_stack_nc_push(this)
  use pfunit
  use stack
  use nmsh
  implicit none
  class(test_stack_nc_case), intent(inout) :: this
  type(stack_nc_t) :: s
  integer :: i, j, k
  type(nmsh_curve_el_t) :: data
  type(nmsh_curve_el_t), pointer :: curve_ptr(:)

  call s%init()
  do i = 1, 64
     data%e = i
     do j = 1, 12
        data%type(j) = i + j
        do k = 1, 5
           data%curve_data(k, j) = dble(i + 10 * j + k)
        end do
     end do
     call s%push(data)
  end do
  ! Pushing data should make the stack non-empty without reallocating early.
  @assertEqual(s%size_, 64, message='Unnecessary reallocation')
  @assertEqual(s%top_, s%size_, message='Corrupt size')
  @assertFalse(s%is_empty())

  do i = 1, 2
     data%e = i + 64
     do j = 1, 12
        data%type(j) = i + 64 + j
        do k = 1, 5
           data%curve_data(k, j) = dble(i + 64 + 10 * j + k)
        end do
     end do
     call s%push(data)
  end do
  ! Crossing the initial capacity should resize once and preserve order.
  @assertEqual(s%size_, 128, message='Unnecessary reallocation')
  @assertEqual(s%top_, 66, message='Corrupt size')

  curve_ptr => s%array()
  do i = 1, 66
     @assertEqual(curve_ptr(i)%e, i)
     do j = 1, 12
        @assertEqual(curve_ptr(i)%type(j), i + j)
        do k = 1, 5
           @assertEqual(curve_ptr(i)%curve_data(k, j), dble(i + 10 * j + k))
        end do
     end do
  end do

end subroutine test_stack_nc_push

@test
subroutine test_stack_nc_pop(this)
  use pfunit
  use stack
  use nmsh
  implicit none
  class(test_stack_nc_case), intent(inout) :: this
  type(stack_nc_t) :: s
  integer :: i, j, k
  type(nmsh_curve_el_t) :: data

  call s%init()
  do i = 1, 66
     data%e = i
     do j = 1, 12
        data%type(j) = i + j
        do k = 1, 5
           data%curve_data(k, j) = dble(i + 10 * j + k)
        end do
     end do
     call s%push(data)
  end do

  do i = 66, 1, -1
     data = s%pop()
     @assertEqual(data%e, i)
     do j = 1, 12
        @assertEqual(data%type(j), i + j)
        do k = 1, 5
           @assertEqual(data%curve_data(k, j), dble(i + 10 * j + k))
        end do
     end do
  end do

  ! Popping all entries should restore the empty-state markers.
  @assertEqual(s%top_, 0, message='Leftover data')
  @assertEqual(s%size_, 128, message='Corrupt size')
  @assertTrue(s%is_empty())

end subroutine test_stack_nc_pop

@test
subroutine test_stack_nc_clear(this)
  use pfunit
  use stack
  use nmsh
  implicit none
  class(test_stack_nc_case), intent(inout) :: this
  type(stack_nc_t) :: s
  integer :: i
  type(nmsh_curve_el_t) :: data

  call s%init()
  do i = 1, 66
     data%e = i
     call s%push(data)
  end do
  call s%clear()
  ! Clearing should drop the logical contents without shrinking storage.
  @assertEqual(s%size(), s%top_)
  @assertEqual(s%top_, 0, message='Corrupt top marker')
  @assertTrue(s%is_empty())

end subroutine test_stack_nc_clear

end module test_stack_nc
