module test_htable_pt
contains
@test
subroutine test_htable_init_pt
  use pfunit
  use htable
  use num_types
  use point
  use tuple
  implicit none
  type(htable_pt_t) :: h
  integer :: data_i4
  integer(kind=i8) :: data_i8
  real(kind=dp) :: data_r8
  type(tuple_i4_t) :: data_ti4
  type(tuple4_i4_t) :: data_t4i4
  type(point_t) :: data_pt

  call h%init(4, data_i4)
  @assertEqual(h%num_entries(), 0)

  call h%init(4, data_i8)
  @assertEqual(h%num_entries(), 0)

  call h%init(4, data_r8)
  @assertEqual(h%num_entries(), 0)

  call h%init(4, data_ti4)
  @assertEqual(h%num_entries(), 0)

  call h%init(4, data_t4i4)
  @assertEqual(h%num_entries(), 0)

  call h%init(4, data_pt)
  @assertEqual(h%num_entries(), 0)

end subroutine test_htable_init_pt

@test
subroutine test_htable_add_pt
  use pfunit
  use htable
  use num_types
  use point
  use tuple
  implicit none
  type(htable_pt_t) :: h1, h2, h3, h4, h5, h6
  integer :: i
  integer :: data_i4
  integer(kind=i8) :: data_i8
  real(kind=dp) :: data_r8
  type(tuple_i4_t) :: data_ti4
  type(tuple4_i4_t) :: data_t4i4
  type(point_t) :: data_pt, key

  call h1%init(4, data=data_i4)
  call h2%init(4, data=data_i8)
  call h3%init(4, data=data_r8)
  call h4%init(4, data=data_ti4)
  call h5%init(4, data=data_t4i4)
  call h6%init(4, data=data_pt)

  do i = 1, 6
     call key%init(dble(i), dble(i**2), dble(i**3))
     data_i4 = -i
     data_i8 = int(-i, i8)
     data_r8 = dble(-i)
     data_ti4 = (/-i, i/)
     data_t4i4 = (/-i, i, -i , i/)
     call data_pt%init(dble(i), dble(-i), dble(i*i))

     call h1%set(key, data_i4)
     call h2%set(key, data_i8)
     call h3%set(key, data_r8)
     call h4%set(key, data_ti4)
     call h5%set(key, data_t4i4)
     call h6%set(key, data_pt)
  end do

  @assertEqual(h1%num_entries(), 6)
  @assertEqual(h2%num_entries(), 6)
  @assertEqual(h3%num_entries(), 6)
  @assertEqual(h4%num_entries(), 6)
  @assertEqual(h5%num_entries(), 6)
  @assertEqual(h6%num_entries(), 6)

  ! Insert new keys past the initial occupancy to exercise growth clearly.
  do i = 7, 8
     call key%init(dble(i), dble(i**2), dble(i**3))
     data_i4 = -i
     data_i8 = int(-i, i8)
     data_r8 = dble(-i)
     data_ti4 = (/-i, i/)
     data_t4i4 = (/-i, i, -i , i/)
     call data_pt%init(dble(i), dble(-i), dble(i*i))

     call h1%set(key, data_i4)
     call h2%set(key, data_i8)
     call h3%set(key, data_r8)
     call h4%set(key, data_ti4)
     call h5%set(key, data_t4i4)
     call h6%set(key, data_pt)
  end do

  @assertEqual(h1%num_entries(), 8)
  @assertEqual(h2%num_entries(), 8)
  @assertEqual(h3%num_entries(), 8)
  @assertEqual(h4%num_entries(), 8)
  @assertEqual(h5%num_entries(), 8)
  @assertEqual(h6%num_entries(), 8)

end subroutine test_htable_add_pt

@test
subroutine test_htable_contract_pt
  use pfunit
  use htable
  use point
  implicit none
  type(htable_pt_t) :: h
  type(htable_iter_pt_t) :: it
  type(point_t) :: key, key_expected, data_pt, copy_pt
  type(point_t), pointer :: kp, vp

  call h%init(3, data=data_pt)
  ! Small requested sizes should round up to the implementation minimum.
  @assertEqual(h%get_size(), 4)

  call key%init(2d0, 4d0, 8d0)
  call data_pt%init(-2d0, -4d0, -8d0)
  call h%set(key, data_pt)
  call data_pt%init(-20d0, -40d0, -80d0)
  call h%set(key, data_pt)
  ! Updating an existing key must overwrite the value without growing entries.
  @assertEqual(h%num_entries(), 1)
  @assertEqual(h%get(key, copy_pt), 0)
  call data_pt%init(-20d0, -40d0, -80d0)
  @assertTrue(copy_pt .eq. data_pt)

  call h%remove(key)
  call data_pt%init(-200d0, -400d0, -800d0)
  call h%set(key, data_pt)
  ! Re-inserting a removed key must work through the tombstone path.
  @assertEqual(h%num_entries(), 1)
  @assertEqual(h%get(key, copy_pt), 0)
  call data_pt%init(-200d0, -400d0, -800d0)
  @assertTrue(copy_pt .eq. data_pt)

  call it%init(h)
  @assertTrue(it%next())
  call it%data(copy_pt)
  call data_pt%init(-200d0, -400d0, -800d0)
  @assertTrue(copy_pt .eq. data_pt)
  call it%reset()
  ! Reset should restart iteration from the first valid entry.
  @assertTrue(it%next())
  kp => it%key()
  vp => it%value()
  call key_expected%init(2d0, 4d0, 8d0)
  @assertTrue(kp .eq. key_expected)
  call data_pt%init(-200d0, -400d0, -800d0)
  @assertTrue(vp .eq. data_pt)

end subroutine test_htable_contract_pt

@test
subroutine test_htable_clear_pt
  use pfunit
  use htable
  use point
  implicit none
  type(htable_pt_t) :: h
  integer :: i
  type(point_t) :: key, data

  call h%init(64)

  do i = 1, 42
     call key%init(dble(i), dble(i**2), dble(i**3))
     call data%init(dble(-i), dble(-i**2), dble(-i**3))
     call h%set(key, data)
  end do
  @assertEqual(h%num_entries(), 42)
  call h%clear()
  @assertEqual(h%num_entries(), 0)

end subroutine test_htable_clear_pt

@test
subroutine test_htable_free_pt
  use pfunit
  use htable
  use point
  implicit none
  type(htable_pt_t) :: h
  integer :: i
  type(point_t) :: key, data

  call h%init(64)

  do i = 1, 42
     call key%init(dble(i), dble(i**2), dble(i**3))
     call data%init(dble(-i), dble(-i**2), dble(-i**3))
     call h%set(key, data)
  end do
  @assertEqual(h%num_entries(), 42)
  call h%free()
  @assertEqual(h%num_entries(), 0)

end subroutine test_htable_free_pt


@test
subroutine test_htable_get_pt
  use pfunit
  use htable
  use num_types
  use point
  use tuple
  implicit none
  type(htable_pt_t) :: h1, h2, h3, h4, h5, h6
  integer :: i
  integer :: data_i4
  integer(kind=i8) :: data_i8
  real(kind=dp) :: data_r8
  type(tuple_i4_t) :: data_ti4, ti4
  type(tuple4_i4_t) :: data_t4i4, t4i4
  type(point_t) :: data_pt, pt, key

  call h1%init(4, data=data_i4)
  call h2%init(4, data=data_i8)
  call h3%init(4, data=data_r8)
  call h4%init(4, data=data_ti4)
  call h5%init(4, data=data_t4i4)
  call h6%init(4, data=data_pt)

  do i = 1, 42
     call key%init(dble(i), dble(i**2), dble(i**3))
     data_i4 = -i
     data_i8 = int(-i, i8)
     data_r8 = dble(-i)
     data_ti4 = (/-i, i/)
     data_t4i4 = (/-i, i, -i , i/)
     call data_pt%init(dble(i), dble(-i), dble(i*i))

     call h1%set(key, data_i4)
     call h2%set(key, data_i8)
     call h3%set(key, data_r8)
     call h4%set(key, data_ti4)
     call h5%set(key, data_t4i4)
     call h6%set(key, data_pt)
  end do

  do i = 1, 42
     call key%init(dble(i), dble(i**2), dble(i**3))
     @assertEqual(h1%get(key, data_i4), 0)
     @assertEqual(h2%get(key, data_i8), 0)
     @assertEqual(h3%get(key, data_r8), 0)
     @assertEqual(h4%get(key, data_ti4), 0)
     @assertEqual(h5%get(key, data_t4i4), 0)
     @assertEqual(h6%get(key, data_pt), 0)

     ti4 = (/-i, i/)
     t4i4 = (/-i, i, -i, i/)
     call pt%init(dble(i), dble(-i), dble(i*i))

     @assertEqual(data_i4, -i)
     @assertEqual(data_i8, int(-i, i8))
     @assertEqual(data_r8, dble(-i))
     @assertTrue(data_ti4 .eq. ti4)
     @assertTrue(data_t4i4 .eq. t4i4)
     @assertTrue(data_pt .eq. pt)
  end do

  do i = 42, 1, -1
     call key%init(dble(i), dble(i**2), dble(i**3))
     @assertEqual(h1%get(key, data_i4), 0)
     @assertEqual(h2%get(key, data_i8), 0)
     @assertEqual(h3%get(key, data_r8), 0)
     @assertEqual(h4%get(key, data_ti4), 0)
     @assertEqual(h5%get(key, data_t4i4), 0)
     @assertEqual(h6%get(key, data_pt), 0)

     ti4 = (/-i, i/)
     t4i4 = (/-i, i, -i, i/)
     call pt%init(dble(i), dble(-i), dble(i*i))

     @assertEqual(data_i4, -i)
     @assertEqual(data_i8, int(-i, i8))
     @assertEqual(data_r8, dble(-i))
     @assertTrue(data_ti4 .eq. ti4)
     @assertTrue(data_t4i4 .eq. t4i4)
     @assertTrue(data_pt .eq. pt)
  end do

  do i = 1, 42, 2
     call key%init(dble(i), dble(i**2), dble(i**3))
     @assertEqual(h1%get(key, data_i4), 0)
     @assertEqual(h2%get(key, data_i8), 0)
     @assertEqual(h3%get(key, data_r8), 0)
     @assertEqual(h4%get(key, data_ti4), 0)
     @assertEqual(h5%get(key, data_t4i4), 0)
     @assertEqual(h6%get(key, data_pt), 0)

     ti4 = (/-i, i/)
     t4i4 = (/-i, i, -i, i/)
     call pt%init(dble(i), dble(-i), dble(i*i))

     @assertEqual(data_i4, -i)
     @assertEqual(data_i8, int(-i, i8))
     @assertEqual(data_r8, dble(-i))
     @assertTrue(data_ti4 .eq. ti4)
     @assertTrue(data_t4i4 .eq. t4i4)
     @assertTrue(data_pt .eq. pt)
  end do

end subroutine test_htable_get_pt


@test
subroutine test_htable_remove_pt
  use pfunit
  use htable
  use num_types
  use point
  use tuple
  implicit none
  type(htable_pt_t) :: h1, h2, h3, h4, h5, h6
  integer :: i
  integer :: data_i4
  integer(kind=i8) :: data_i8
  real(kind=dp) :: data_r8
  type(tuple_i4_t) :: data_ti4, ti4
  type(tuple4_i4_t) :: data_t4i4, t4i4
  type(point_t) :: data_pt, pt, key

  call h1%init(4, data=data_i4)
  call h2%init(4, data=data_i8)
  call h3%init(4, data=data_r8)
  call h4%init(4, data=data_ti4)
  call h5%init(4, data=data_t4i4)
  call h6%init(4, data=data_pt)

  do i = 1, 42
     call key%init(dble(i), dble(i**2), dble(i**3))
     data_i4 = -i
     data_i8 = int(-i, i8)
     data_r8 = dble(-i)
     data_ti4 = (/-i, i/)
     data_t4i4 = (/-i, i, -i , i/)
     call data_pt%init(dble(i), dble(-i), dble(i*i))

     call h1%set(key, data_i4)
     call h2%set(key, data_i8)
     call h3%set(key, data_r8)
     call h4%set(key, data_ti4)
     call h5%set(key, data_t4i4)
     call h6%set(key, data_pt)
  end do

  do i = 1, 42, 2
     call key%init(dble(i), dble(i**2), dble(i**3))
     call h1%remove(key)
     call h2%remove(key)
     call h3%remove(key)
     call h4%remove(key)
     call h5%remove(key)
     call h6%remove(key)
  end do
  @assertEqual(h1%num_entries(), 21)
  @assertEqual(h2%num_entries(), 21)
  @assertEqual(h3%num_entries(), 21)
  @assertEqual(h4%num_entries(), 21)
  @assertEqual(h5%num_entries(), 21)
  @assertEqual(h6%num_entries(), 21)

  do i = 2, 42, 2
     call key%init(dble(i), dble(i**2), dble(i**3))
     @assertEqual(h1%get(key, data_i4), 0)
     @assertEqual(h2%get(key, data_i8), 0)
     @assertEqual(h3%get(key, data_r8), 0)
     @assertEqual(h4%get(key, data_ti4), 0)
     @assertEqual(h5%get(key, data_t4i4), 0)
     @assertEqual(h6%get(key, data_pt), 0)

     ti4 = (/-i, i/)
     t4i4 = (/-i, i, -i, i/)
     call pt%init(dble(i), dble(-i), dble(i*i))

     @assertEqual(data_i4, -i)
     @assertEqual(data_i8, int(-i, i8))
     @assertEqual(data_r8, dble(-i))
     @assertTrue(data_ti4 .eq. ti4)
     @assertTrue(data_t4i4 .eq. t4i4)
     @assertTrue(data_pt .eq. pt)
  end do


  do i = 1, 42, 2
     call key%init(dble(i), dble(i**2), dble(i**3))
     @assertEqual(h1%get(key, data_i4), 1)
     @assertEqual(h2%get(key, data_i8), 1)
     @assertEqual(h3%get(key, data_r8), 1)
     @assertEqual(h4%get(key, data_ti4), 1)
     @assertEqual(h5%get(key, data_t4i4), 1)
     @assertEqual(h6%get(key, data_pt), 1)
  end do

end subroutine test_htable_remove_pt

@test
subroutine test_htable_iter_pt
  use pfunit
  use htable
  use point
  implicit none
  type(htable_pt_t) :: h
  type(htable_iter_pt_t) :: it
  integer :: i, rcode
  type(point_t) :: key, data_pt
  type(point_t), pointer :: kp, dptp

  call h%init(4, data=data_pt)

  do i = 1, 42
     call key%init(dble(i), dble(i**2), dble(i**3))
     call data_pt%init(-dble(i), -dble(i**2), -dble(i**3))
     call h%set(key, data_pt)
  end do

  call it%init(h)

  i = 0
  do while(it%next())
     kp => it%key()
     dptp=> it%value()
     ! Iterator traversal should expose the same key/value pairs as get().
     call data_pt%init(-kp%x(1), -kp%x(2), -kp%x(3))
     @assertTrue(data_pt .eq. dptp)

     rcode = h%get(kp, data_pt)
     @assertEqual(rcode, 0)
     @assertTrue(data_pt .eq. dptp)
     if (rcode .eq. 0) i = i + 1
  end do
  @assertEqual(i, 42)

end subroutine test_htable_iter_pt

end module test_htable_pt
