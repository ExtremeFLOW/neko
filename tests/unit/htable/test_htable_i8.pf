module test_htable_i8
contains
@test
subroutine test_htable_init_i8
  use pfunit
  use htable
  use num_types
  use point
  use tuple
  implicit none
  type(htable_i8_t) :: h
  integer :: data_i4
  integer(kind=i8) :: data_i8
  real(kind=dp) :: data_r8
  type(tuple_i4_t) :: data_ti4
  type(tuple4_i4_t) :: data_t4i4
  type(point_t) :: data_pt

  call h%init(4, data_i4)
  @assertEqual(h%num_entries(), 0)

  call h%init(4, data_i8)
  @assertEqual(h%num_entries(), 0)

  call h%init(4, data_r8)
  @assertEqual(h%num_entries(), 0)

  call h%init(4, data_ti4)
  @assertEqual(h%num_entries(), 0)

  call h%init(4, data_t4i4)
  @assertEqual(h%num_entries(), 0)

  call h%init(4, data_pt)
  @assertEqual(h%num_entries(), 0)

end subroutine test_htable_init_i8

@test
subroutine test_htable_add_i8
  use pfunit
  use htable
  use num_types
  use point
  use tuple
  implicit none
  type(htable_i8_t) :: h1, h2, h3, h4, h5, h6
  integer :: i
  integer :: data_i4
  integer(kind=i8) :: data_i8, key
  real(kind=dp) :: data_r8
  type(tuple_i4_t) :: data_ti4
  type(tuple4_i4_t) :: data_t4i4
  type(point_t) :: data_pt

  call h1%init(4, data=data_i4)
  call h2%init(4, data=data_i8)
  call h3%init(4, data=data_r8)
  call h4%init(4, data=data_ti4)
  call h5%init(4, data=data_t4i4)
  call h6%init(4, data=data_pt)

  do i = 1, 6
     key = int(i, i8)
     data_i4 = -i
     data_i8 = int(-i, i8)
     data_r8 = dble(-i)
     data_ti4 = (/-i, i/)
     data_t4i4 = (/-i, i, -i , i/)
     call data_pt%init(dble(i), dble(-i), dble(i*i))

     call h1%set(key, data_i4)
     call h2%set(key, data_i8)
     call h3%set(key, data_r8)
     call h4%set(key, data_ti4)
     call h5%set(key, data_t4i4)
     call h6%set(key, data_pt)
  end do

  @assertEqual(h1%num_entries(), 6)
  @assertEqual(h2%num_entries(), 6)
  @assertEqual(h3%num_entries(), 6)
  @assertEqual(h4%num_entries(), 6)
  @assertEqual(h5%num_entries(), 6)
  @assertEqual(h6%num_entries(), 6)

  ! Insert new keys past the initial occupancy to exercise growth clearly.
  do i = 7, 8
     key = int(i, i8)
     data_i4 = -i
     data_i8 = int(-i, i8)
     data_r8 = dble(-i)
     data_ti4 = (/-i, i/)
     data_t4i4 = (/-i, i, -i , i/)
     call data_pt%init(dble(i), dble(-i), dble(i*i))

     call h1%set(key, data_i4)
     call h2%set(key, data_i8)
     call h3%set(key, data_r8)
     call h4%set(key, data_ti4)
     call h5%set(key, data_t4i4)
     call h6%set(key, data_pt)
  end do

  @assertEqual(h1%num_entries(), 8)
  @assertEqual(h2%num_entries(), 8)
  @assertEqual(h3%num_entries(), 8)
  @assertEqual(h4%num_entries(), 8)
  @assertEqual(h5%num_entries(), 8)
  @assertEqual(h6%num_entries(), 8)

end subroutine test_htable_add_i8

@test
subroutine test_htable_contract_i8
  use pfunit
  use htable
  use num_types, only : i8
  implicit none
  type(htable_i8_t) :: h
  type(htable_iter_i8_t) :: it
  integer(kind=i8) :: key, data_i8, copy_i8
  integer(kind=i8), pointer :: kp, vp

  call h%init(3, data=data_i8)
  ! Small requested sizes should round up to the implementation minimum.
  @assertEqual(h%get_size(), 4)

  key = int(2, i8)
  data_i8 = int(-2, i8)
  call h%set(key, data_i8)
  data_i8 = int(-20, i8)
  call h%set(key, data_i8)
  ! Updating an existing key must overwrite the value without growing entries.
  @assertEqual(h%num_entries(), 1)
  copy_i8 = 0
  @assertEqual(h%get(key, copy_i8), 0)
  @assertEqual(copy_i8, int(-20, i8))

  call h%remove(key)
  data_i8 = int(-200, i8)
  call h%set(key, data_i8)
  ! Re-inserting a removed key must work through the tombstone path.
  @assertEqual(h%num_entries(), 1)
  copy_i8 = 0
  @assertEqual(h%get(key, copy_i8), 0)
  @assertEqual(copy_i8, int(-200, i8))

  call it%init(h)
  @assertTrue(it%next())
  call it%data(copy_i8)
  @assertEqual(copy_i8, int(-200, i8))
  call it%reset()
  ! Reset should restart iteration from the first valid entry.
  @assertTrue(it%next())
  kp => it%key()
  vp => it%value()
  @assertEqual(kp, key)
  @assertEqual(vp, int(-200, i8))

end subroutine test_htable_contract_i8

@test
subroutine test_htable_clear_i8
  use pfunit
  use htable
  use num_types, only : i8
  implicit none
  type(htable_i8_t) :: h
  integer :: i
  integer(kind=i8) :: key, data

  call h%init(64)

  do i = 1, 42
     key = int(i, i8)
     data = int(-i, i8)
     call h%set(key, data)
  end do
  @assertEqual(h%num_entries(), 42)
  call h%clear()
  @assertEqual(h%num_entries(), 0)

end subroutine test_htable_clear_i8

@test
subroutine test_htable_free_i8
  use pfunit
  use htable
  use num_types, only : i8
  implicit none
  type(htable_i8_t) :: h
  integer :: i
  integer(kind=i8) :: key, data

  call h%init(64)

  do i = 1, 42
     key = int(i, i8)
     data = int(-i, i8)
     call h%set(key, data)
  end do
  @assertEqual(h%num_entries(), 42)
  call h%free()
  @assertEqual(h%num_entries(), 0)

end subroutine test_htable_free_i8


@test
subroutine test_htable_get_i8
  use pfunit
  use htable
  use num_types
  use point
  use tuple
  implicit none
  type(htable_i8_t) :: h1, h2, h3, h4, h5, h6
  integer :: i
  integer :: data_i4
  integer(kind=i8) :: data_i8, key
  real(kind=dp) :: data_r8
  type(tuple_i4_t) :: data_ti4, ti4
  type(tuple4_i4_t) :: data_t4i4, t4i4
  type(point_t) :: data_pt, pt

  call h1%init(4, data=data_i4)
  call h2%init(4, data=data_i8)
  call h3%init(4, data=data_r8)
  call h4%init(4, data=data_ti4)
  call h5%init(4, data=data_t4i4)
  call h6%init(4, data=data_pt)

  do i = 1, 42
     key = int(i, i8)
     data_i4 = -i
     data_i8 = int(-i, i8)
     data_r8 = dble(-i)
     data_ti4 = (/-i, i/)
     data_t4i4 = (/-i, i, -i , i/)
     call data_pt%init(dble(i), dble(-i), dble(i*i))

     call h1%set(key, data_i4)
     call h2%set(key, data_i8)
     call h3%set(key, data_r8)
     call h4%set(key, data_ti4)
     call h5%set(key, data_t4i4)
     call h6%set(key, data_pt)
  end do

  do i = 1, 42
     key = int(i, i8)
     @assertEqual(h1%get(key, data_i4), 0)
     @assertEqual(h2%get(key, data_i8), 0)
     @assertEqual(h3%get(key, data_r8), 0)
     @assertEqual(h4%get(key, data_ti4), 0)
     @assertEqual(h5%get(key, data_t4i4), 0)
     @assertEqual(h6%get(key, data_pt), 0)

     ti4 = (/-i, i/)
     t4i4 = (/-i, i, -i, i/)
     call pt%init(dble(i), dble(-i), dble(i*i))

     @assertEqual(data_i4, -i)
     @assertEqual(data_i8, int(-i, i8))
     @assertEqual(data_r8, dble(-i))
     @assertTrue(data_ti4 .eq. ti4)
     @assertTrue(data_t4i4 .eq. t4i4)
     @assertTrue(data_pt .eq. pt)
  end do

  do i = 42, 1, -1
     key = int(i, i8)
     @assertEqual(h1%get(key, data_i4), 0)
     @assertEqual(h2%get(key, data_i8), 0)
     @assertEqual(h3%get(key, data_r8), 0)
     @assertEqual(h4%get(key, data_ti4), 0)
     @assertEqual(h5%get(key, data_t4i4), 0)
     @assertEqual(h6%get(key, data_pt), 0)

     ti4 = (/-i, i/)
     t4i4 = (/-i, i, -i, i/)
     call pt%init(dble(i), dble(-i), dble(i*i))

     @assertEqual(data_i4, -i)
     @assertEqual(data_i8, int(-i, i8))
     @assertEqual(data_r8, dble(-i))
     @assertTrue(data_ti4 .eq. ti4)
     @assertTrue(data_t4i4 .eq. t4i4)
     @assertTrue(data_pt .eq. pt)
  end do

  do i = 1, 42, 2
     key = int(i, i8)
     @assertEqual(h1%get(key, data_i4), 0)
     @assertEqual(h2%get(key, data_i8), 0)
     @assertEqual(h3%get(key, data_r8), 0)
     @assertEqual(h4%get(key, data_ti4), 0)
     @assertEqual(h5%get(key, data_t4i4), 0)
     @assertEqual(h6%get(key, data_pt), 0)

     ti4 = (/-i, i/)
     t4i4 = (/-i, i, -i, i/)
     call pt%init(dble(i), dble(-i), dble(i*i))

     @assertEqual(data_i4, -i)
     @assertEqual(data_i8, int(-i, i8))
     @assertEqual(data_r8, dble(-i))
     @assertTrue(data_ti4 .eq. ti4)
     @assertTrue(data_t4i4 .eq. t4i4)
     @assertTrue(data_pt .eq. pt)
  end do

end subroutine test_htable_get_i8


@test
subroutine test_htable_remove_i8
  use pfunit
  use htable
  use num_types
  use point
  use tuple
  implicit none
  type(htable_i8_t) :: h1, h2, h3, h4, h5, h6
  integer :: i
  integer :: data_i4
  integer(kind=i8) :: data_i8, key
  real(kind=dp) :: data_r8
  type(tuple_i4_t) :: data_ti4, ti4
  type(tuple4_i4_t) :: data_t4i4, t4i4
  type(point_t) :: data_pt, pt

  call h1%init(4, data=data_i4)
  call h2%init(4, data=data_i8)
  call h3%init(4, data=data_r8)
  call h4%init(4, data=data_ti4)
  call h5%init(4, data=data_t4i4)
  call h6%init(4, data=data_pt)

  do i = 1, 42
     key = int(i, i8)
     data_i4 = -i
     data_i8 = int(-i, i8)
     data_r8 = dble(-i)
     data_ti4 = (/-i, i/)
     data_t4i4 = (/-i, i, -i , i/)
     call data_pt%init(dble(i), dble(-i), dble(i*i))

     call h1%set(key, data_i4)
     call h2%set(key, data_i8)
     call h3%set(key, data_r8)
     call h4%set(key, data_ti4)
     call h5%set(key, data_t4i4)
     call h6%set(key, data_pt)
  end do

  do i = 1, 42, 2
     key = int(i, i8)
     call h1%remove(key)
     call h2%remove(key)
     call h3%remove(key)
     call h4%remove(key)
     call h5%remove(key)
     call h6%remove(key)
  end do
  @assertEqual(h1%num_entries(), 21)
  @assertEqual(h2%num_entries(), 21)
  @assertEqual(h3%num_entries(), 21)
  @assertEqual(h4%num_entries(), 21)
  @assertEqual(h5%num_entries(), 21)
  @assertEqual(h6%num_entries(), 21)

  do i = 2, 42, 2
     key = int(i, i8)
     @assertEqual(h1%get(key, data_i4), 0)
     @assertEqual(h2%get(key, data_i8), 0)
     @assertEqual(h3%get(key, data_r8), 0)
     @assertEqual(h4%get(key, data_ti4), 0)
     @assertEqual(h5%get(key, data_t4i4), 0)
     @assertEqual(h6%get(key, data_pt), 0)

     ti4 = (/-i, i/)
     t4i4 = (/-i, i, -i, i/)
     call pt%init(dble(i), dble(-i), dble(i*i))

     @assertEqual(data_i4, -i)
     @assertEqual(data_i8, int(-i, i8))
     @assertEqual(data_r8, dble(-i))
     @assertTrue(data_ti4 .eq. ti4)
     @assertTrue(data_t4i4 .eq. t4i4)
     @assertTrue(data_pt .eq. pt)
  end do


  do i = 1, 42, 2
     key = int(i, i8)
     @assertEqual(h1%get(key, data_i4), 1)
     @assertEqual(h2%get(key, data_i8), 1)
     @assertEqual(h3%get(key, data_r8), 1)
     @assertEqual(h4%get(key, data_ti4), 1)
     @assertEqual(h5%get(key, data_t4i4), 1)
     @assertEqual(h6%get(key, data_pt), 1)
  end do

end subroutine test_htable_remove_i8

@test
subroutine test_htable_iter_i8
  use pfunit
  use htable
  use num_types
  implicit none
  type(htable_i8_t) :: h
  type(htable_iter_i8_t) :: it
  integer :: i, rcode
  integer(kind=i8) :: key, data_i8
  integer(kind=i8), pointer :: kp, di8p

  call h%init(4, data=data_i8)

  do i = 1, 42
     key = int(i, i8)
     data_i8 = int(-i, i8)
     call h%set(key, data_i8)
  end do

  call it%init(h)

  i = 0
  do while(it%next())
     kp => it%key()
     di8p=> it%value()

     ! Iterator traversal should expose the same key/value pairs as get().
     data_i8 = -kp
     @assertEqual(data_i8, di8p)

     rcode = h%get(kp, data_i8)
     @assertEqual(rcode, 0)
     @assertEqual(data_i8, di8p)
     if (rcode .eq. 0) i = i + 1
  end do
  @assertEqual(i, 42)

end subroutine test_htable_iter_i8

end module test_htable_i8
