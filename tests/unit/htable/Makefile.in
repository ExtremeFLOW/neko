ifneq ("$(wildcard @PFUNIT_DIR@/include/PFUNIT.mk)", "")
include @PFUNIT_DIR@/include/PFUNIT.mk
endif
FFLAGS += $(PFUNIT_EXTRA_FFLAGS) @NEKO_PKG_FCFLAGS@ -I@top_builddir@/src
FC = @FC@

%.o : %.F90
	$(FC) -c $(FFLAGS) $<


check: htable_test


htable_test_TESTS := test_htable_i4.pf\
		     test_htable_i8.pf\
		     test_htable_r8.pf\
		     test_htable_pt.pf\
		     test_htable_i4t2.pf\
		     test_htable_i4t4.pf
htable_test_OTHER_LIBRARIES = -L@top_builddir@/src/.libs/ -lneko
$(eval $(call make_pfunit_test,htable_test))
htable_test.inc: Makefile

distclean:
clean:
	$(RM) *.o *.mod *.a  *.inc *.F90 htable_test



all:
html:
install:
distdir:
