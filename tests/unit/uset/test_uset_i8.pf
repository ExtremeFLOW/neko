module test_uset_i8
  use pfunit
  use device, only : device_init, device_finalize
  use neko_config, only : NEKO_BCKND_DEVICE
  implicit none

  @TestCase
  type, extends(TestCase) :: test_uset_i8_case
   contains
     procedure :: setUp
     procedure :: tearDown
  end type test_uset_i8_case

contains

  subroutine setUp(this)
    class(test_uset_i8_case), intent(inout) :: this
    if (NEKO_BCKND_DEVICE .eq. 1) then
       call device_init
    end if
  end subroutine setUp

  subroutine tearDown(this)
    class(test_uset_i8_case), intent(inout) :: this
    if (NEKO_BCKND_DEVICE .eq. 1) then
       call device_finalize
    end if
  end subroutine tearDown

@test
subroutine test_uset_init_i8(this)
  use pfunit
  use uset
  class(test_uset_i8_case), intent(inout) :: this
  type(uset_i8_t) :: s

  call s%init()
  @assertEqual(s%size(), 0)
    
end subroutine test_uset_init_i8

@test
subroutine test_uset_free_i8(this)
  use pfunit
  use uset
  class(test_uset_i8_case), intent(inout) :: this
  type(uset_i8_t) :: s

  call s%init()
  call s%free()
  @assertEqual(s%size(), 0)
    
end subroutine test_uset_free_i8

@test
subroutine test_uset_size_i8(this)
  use pfunit
  use uset
  use num_types, only : i8
  class(test_uset_i8_case), intent(inout) :: this
  type(uset_i8_t) :: s
  integer :: i
  integer(kind=i8) :: data

  call s%init()
  do i = 1, 64
     data = int(i, i8)
     call s%add(data)
  end do
  @assertEqual(s%size(), 64)

  do i = 1, 2
     data = int(i + 64, i8)
     call s%add(data)
  end do
  @assertEqual(s%size(), 66)

  do i = 1, 10
     data = int(i, i8)
     call s%add(data)
  end do
  ! Re-adding existing members must not increase the cardinality.
  @assertEqual(s%size(), 66)
    
end subroutine test_uset_size_i8

@test
subroutine test_uset_clear_i8(this)
  use pfunit
  use uset
  use num_types, only : i8
  class(test_uset_i8_case), intent(inout) :: this
  type(uset_i8_t) :: s
  integer :: i
  integer(kind=i8) :: data

  call s%init()
  do i = 1, 64
     data = int(i, i8)
     call s%add(data)
  end do
  call s%clear()
  @assertEqual(s%size(), 0)

  do i = 1, 42
     data = int(i, i8)
     call s%add(data)
  end do
  @assertEqual(s%size(), 42)
    
end subroutine test_uset_clear_i8

@test
subroutine test_uset_element_i8(this)
  use pfunit
  use uset
  use num_types, only : i8
  class(test_uset_i8_case), intent(inout) :: this
  type(uset_i8_t) :: s
  integer :: i
  integer(kind=i8) :: data

  call s%init()
  do i = 1, 64
     data = int(i, i8)
     call s%add(data)
  end do
  
  do i = 1, 64
     data = int(i, i8)
     @assertTrue(s%element(data))
  end do

  do i = 1, 2
     data = int(i + 64, i8)
     call s%add(data)
  end do
  
  do i = 1, 66
     data = int(i, i8)
     @assertTrue(s%element(data))
  end do

  ! A value never inserted into the set must not be reported as present.
  data = int(-1, i8)
  @assertFalse(s%element(data))

    
end subroutine test_uset_element_i8

@test
subroutine test_uset_remove_i8(this)
  use pfunit
  use uset
  use num_types, only : i8
  class(test_uset_i8_case), intent(inout) :: this
  type(uset_i8_t) :: s
  integer :: i
  integer(kind=i8) :: data

  call s%init()
  do i = 1, 64
     data = int(i, i8)
     call s%add(data)
  end do
  
  do i = 1, 64
     data = int(i, i8)
     @assertTrue(s%element(data))
  end do

  do i = 64, 1, -1
     data = int(i, i8)
     @assertTrue(s%element(data))
  end do

  do i = 1, 64, 2
     data = int(i, i8)
     call s%remove(data)
  end do
  @assertEqual(s%size(), 32)
  
  do i = 1, 64, 2
     data = int(i, i8)
     @assertFalse(s%element(data))
  end do
  
  do i = 2, 64, 2
     data = int(i, i8)
     @assertTrue(s%element(data))
  end do

  ! Removing a missing value should be a no-op for both size and membership.
  data = int(101, i8)
  call s%remove(data)
  @assertEqual(s%size(), 32)
  @assertFalse(s%element(data))
  
end subroutine test_uset_remove_i8

@test
subroutine test_uset_iter_i8(this)
  use pfunit
  use uset
  use num_types, only : i8
  class(test_uset_i8_case), intent(inout) :: this
  type(uset_i8_t) :: s
  integer :: i, n_entries
  integer(kind=i8) :: data

  call s%init()
  do i = 1, 64
     data = int(i, i8)
     call s%add(data)
  end do

  call s%iter_init()
  n_entries = 0
  do while(s%iter_next())
     n_entries = n_entries + 1
     data = s%iter_value()
     @assertTrue(s%element(data))
  end do
  @assertEqual(n_entries, 64)

  ! After clearing, a freshly initialised iterator must terminate immediately.
  call s%clear()
  call s%iter_init()
  @assertFalse(s%iter_next())
  
end subroutine test_uset_iter_i8

end module test_uset_i8
