module test_uset_i4
  use pfunit
  use device, only : device_init, device_finalize
  use neko_config, only : NEKO_BCKND_DEVICE
  implicit none

  @TestCase
  type, extends(TestCase) :: test_uset_i4_case
   contains
     procedure :: setUp
     procedure :: tearDown
  end type test_uset_i4_case

contains

  subroutine setUp(this)
    class(test_uset_i4_case), intent(inout) :: this
    if (NEKO_BCKND_DEVICE .eq. 1) then
       call device_init
    end if
  end subroutine setUp

  subroutine tearDown(this)
    class(test_uset_i4_case), intent(inout) :: this
    if (NEKO_BCKND_DEVICE .eq. 1) then
       call device_finalize
    end if
  end subroutine tearDown

@test
subroutine test_uset_init_i4(this)
  use pfunit
  use uset
  implicit none
  class(test_uset_i4_case), intent(inout) :: this
  type(uset_i4_t) :: s

  call s%init()
  @assertEqual(s%size(), 0)
    
end subroutine test_uset_init_i4

@test
subroutine test_uset_free_i4(this)
  use pfunit
  use uset
  implicit none
  class(test_uset_i4_case), intent(inout) :: this
  type(uset_i4_t) :: s

  call s%init()
  call s%free()
  @assertEqual(s%size(), 0)
    
end subroutine test_uset_free_i4

@test
subroutine test_uset_size_i4(this)
  use pfunit
  use uset
  implicit none
  class(test_uset_i4_case), intent(inout) :: this
  type(uset_i4_t) :: s
  integer :: i, data

  call s%init()
  do i = 1, 64
     data = i
     call s%add(data)
  end do
  @assertEqual(s%size(), 64)

  do i = 1, 2
     data = i + 64
     call s%add(data)
  end do
  @assertEqual(s%size(), 66)

  do i = 1, 10
     data = i
     call s%add(data)
  end do
  ! Re-adding existing members must not increase the cardinality.
  @assertEqual(s%size(), 66)
    
end subroutine test_uset_size_i4

@test
subroutine test_uset_clear_i4(this)
  use pfunit
  use uset
  implicit none
  class(test_uset_i4_case), intent(inout) :: this
  type(uset_i4_t) :: s
  integer :: i, data

  call s%init()
  do i = 1, 64
     data = i
     call s%add(data)
  end do
  call s%clear()
  @assertEqual(s%size(), 0)

  do i = 1, 42
     data = i
     call s%add(data)
  end do
  @assertEqual(s%size(), 42)
    
end subroutine test_uset_clear_i4

@test
subroutine test_uset_element_i4(this)
  use pfunit
  use uset
  implicit none
  class(test_uset_i4_case), intent(inout) :: this
  type(uset_i4_t) :: s
  integer :: i, data

  call s%init()
  do i = 1, 64
     data = i
     call s%add(data)
  end do
  
  do i = 1, 64
     data = i
     @assertTrue(s%element(data))
  end do

  do i = 1, 2
     data = i + 64
     call s%add(data)
  end do
  
  do i = 1, 66
     data = i
     @assertTrue(s%element(data))
  end do

  ! A value never inserted into the set must not be reported as present.
  data = -1
  @assertFalse(s%element(data))

    
end subroutine test_uset_element_i4

@test
subroutine test_uset_remove_i4(this)
  use pfunit
  use uset
  implicit none
  class(test_uset_i4_case), intent(inout) :: this
  type(uset_i4_t) :: s
  integer :: i, data

  call s%init()
  do i = 1, 64
     data = i
     call s%add(data)
  end do
  
  do i = 1, 64
     data = i
     @assertTrue(s%element(data))
  end do

  do i = 64, 1, -1
     data = i
     @assertTrue(s%element(data))
  end do

  do i = 1, 64, 2
     data = i
     call s%remove(data)
  end do
  @assertEqual(s%size(), 32)
  
  do i = 1, 64, 2
     data = i
     @assertFalse(s%element(data))
  end do
  
  do i = 2, 64, 2
     data = i
     @assertTrue(s%element(data))
  end do

  ! Removing a missing value should be a no-op for both size and membership.
  data = 101
  call s%remove(data)
  @assertEqual(s%size(), 32)
  @assertFalse(s%element(data))

  
end subroutine test_uset_remove_i4

@test
subroutine test_uset_iter_i4(this)
  use pfunit
  use uset
  implicit none
  class(test_uset_i4_case), intent(inout) :: this
  type(uset_i4_t) :: s
  integer :: i, data, n_entries

  call s%init()
  do i = 1, 64
     data = i
     call s%add(data)
  end do

  call s%iter_init()
  n_entries = 0
  do while(s%iter_next())
     n_entries = n_entries + 1
     data = s%iter_value()
     @assertTrue(s%element(data))
  end do
  @assertEqual(n_entries, 64)

  ! After clearing, a freshly initialised iterator must terminate immediately.
  call s%clear()
  call s%iter_init()
  @assertFalse(s%iter_next())
  
end subroutine test_uset_iter_i4

end module test_uset_i4
