USEMPI=YES
ifneq ("$(wildcard @PFUNIT_DIR@/include/PFUNIT.mk)", "")
include @PFUNIT_DIR@/include/PFUNIT.mk
endif
FFLAGS += $(PFUNIT_EXTRA_FFLAGS) @NEKO_PKG_FCFLAGS@ -I@top_builddir@/src
FC = @FC@

%.o : %.F90
	$(FC) -c $(FFLAGS) $<


check: boundary_operation_suite


boundary_operation_suite_TESTS := test_boundary_operation.pf
boundary_operation_suite_OTHER_LIBRARIES = -L@top_builddir@/src/.libs -lneko @LDFLAGS@ @LIBS@
$(eval $(call make_pfunit_test,boundary_operation_suite))
boundary_operation_suite.inc: Makefile

distclean:
clean:
	$(RM) *.o *.mod *.a *.inc *.F90 boundary_operation_suite



all:
html:
install:
distdir:
