module test_boundary_operation
  use mpi
  use pfunit
  use boundary_operation, only : boundary_operation_t
  use fluid_pnpn, only : fluid_pnpn_t
  use field, only : field_t
  use mesh, only : mesh_t
  use point, only : point_t
  use space, only : space_t, GLL
  use dofmap, only : dofmap_t
  use gather_scatter, only : gs_t
  use coefs, only : coef_t
  use time_state, only : time_state_t
  use num_types, only : rp
  use case, only : case_t
  use comm, only : NEKO_COMM
  use device, only : device_init, device_finalize, HOST_TO_DEVICE
  use neko_config, only : NEKO_BCKND_DEVICE
  use neko_mpi_types, only : neko_mpi_types_init
  use registry, only : neko_registry
  use utils, only : nonlinear_index
  implicit none

  integer, parameter :: lx_test = 3

  @TestCase
  type, extends(MPITestCase) :: test_boundary_operation_case
   contains
     procedure :: setUp
     procedure :: tearDown
  end type test_boundary_operation_case

contains

  subroutine setUp(this)
    class(test_boundary_operation_case), intent(inout) :: this
    integer :: ierr

    if (NEKO_BCKND_DEVICE .eq. 1) then
       call device_init
    end if

    call MPI_Comm_dup(this%getMpiCommunicator(), NEKO_COMM%mpi_val, ierr)
    call neko_mpi_types_init()
  end subroutine setUp

  subroutine tearDown(this)
    class(test_boundary_operation_case), intent(inout) :: this

    if (NEKO_BCKND_DEVICE .eq. 1) then
       call device_finalize
    end if
  end subroutine tearDown

  !> Verify the default logging and CSV flags on a fresh simcomp.
  @test(npes=[1])
  subroutine test_boundary_operation_defaults(this)
    class(test_boundary_operation_case), intent(inout) :: this
    type(boundary_operation_t) :: simcomp

    @assertTrue(simcomp%log)
    @assertFalse(simcomp%csv_output_enabled)
  end subroutine test_boundary_operation_defaults

  !> Verify CSV output values and output-control gating for boundary operations.
  @test(npes=[1])
  subroutine test_boundary_operation_csv_output(this)
    class(test_boundary_operation_case), intent(inout) :: this
    type(mesh_t) :: msh
    type(space_t) :: Xh
    type(dofmap_t) :: dof
    type(gs_t) :: gs
    type(coef_t) :: coef
    type(field_t) :: fld
    type(boundary_operation_t) :: simcomp
    type(time_state_t) :: time
    character(len=*), parameter :: csv_name = "boundary_operation_test.csv"
    character(len=256) :: line
    logical :: exists
    real(kind=rp) :: row(6)
    integer :: file_unit
    integer :: ios

    call delete_file_if_exists(csv_name)
    inquire(file = csv_name, exist = exists)
    @assertFalse(exists)

    call build_single_hex_fixture(msh, Xh, dof, gs, coef)
    call label_x_faces(msh)

    call fld%init(dof, "xcoord")
    fld%x = dof%x

    ! Set up the simcomp with the test field, labelled zones, requested
    ! operations, and CSV output configuration used below.
    call init_boundary_operation_for_csv_test(simcomp, fld, coef, csv_name)

    call time%init(0.0_rp, 1.0_rp, 0.1_rp)

    time%tstep = 1
    time%t = 0.1_rp
    call simcomp%compute_(time)

    inquire(file = csv_name, exist = exists)
    @assertFalse(exists)

    time%tstep = 2
    time%t = 0.2_rp
    call simcomp%compute_(time)

    inquire(file = csv_name, exist = exists)
    @assertTrue(exists)

    open(newunit = file_unit, file = csv_name, status = "old", action = "read")
    read(file_unit, '(A)') line
    @assertEqual("tstep,time,max,integral,average,min", trim(line))

    read(file_unit, '(A)') line
    read(line, *) row
    @assertEqual(2.0_rp, row(1), tolerance = 1.0e-6_rp)
    @assertEqual(0.2_rp, row(2), tolerance = 1.0e-6_rp)
    @assertEqual(1.0_rp, row(3), tolerance = 1.0e-6_rp)
    @assertEqual(sqrt(2.0_rp), row(4), tolerance = 1.0e-6_rp)
    @assertEqual(0.5_rp, row(5), tolerance = 1.0e-6_rp)
    @assertEqual(0.0_rp, row(6), tolerance = 1.0e-6_rp)

    read(file_unit, '(A)', iostat = ios) line
    @assertTrue(ios .ne. 0)
    close(file_unit)

    call delete_file_if_exists(csv_name)
    call simcomp%free()
    call fld%free()
    call coef%free()
    call gs%free()
    call dof%free()
    call Xh%free()
    call msh%free()
  end subroutine test_boundary_operation_csv_output

  subroutine init_boundary_operation_for_csv_test(simcomp, fld, coef, csv_name)
    type(boundary_operation_t), intent(inout) :: simcomp
    type(field_t), target, intent(inout) :: fld
    type(coef_t), target, intent(inout) :: coef
    character(len=*), intent(in) :: csv_name
    integer :: i
    integer :: l
    integer :: facet
    integer :: idx(4)
    integer :: n_pts

    simcomp = boundary_operation_t()
    simcomp%name = "boundary_operation_test"
    simcomp%field => fld
    simcomp%coef => coef
    simcomp%log = .false.

    allocate(simcomp%zone_indices(2))
    simcomp%zone_indices = [1, 2]

    allocate(character(len=16) :: simcomp%operations(4))
    simcomp%operations = [character(len=16) :: "max", "integral", &
         "average", "min"]

    simcomp%compute_max = .true.
    simcomp%compute_integral = .true.
    simcomp%compute_average = .true.
    simcomp%compute_min = .true.

    call simcomp%bc%init_from_components(simcomp%coef, 0.0_rp)
    simcomp%bc%zone_indices = simcomp%zone_indices
    do i = 1, size(simcomp%zone_indices)
       call simcomp%bc%mark_zone(simcomp%bc%msh%labeled_zones( &
            simcomp%zone_indices(i)))
    end do
    call simcomp%bc%finalize()

    n_pts = simcomp%bc%msk(0)
    if (n_pts .gt. 0) then
       call simcomp%area_msk%init(n_pts)
       call simcomp%field_msk%init(n_pts)
       do l = 1, n_pts
          idx = nonlinear_index(simcomp%bc%msk(l), simcomp%field%Xh%lx, &
               simcomp%field%Xh%ly, simcomp%field%Xh%lz)
          facet = simcomp%bc%facet(l)
          simcomp%area_msk%x(l) = simcomp%coef%get_area(idx(1), idx(2), &
               idx(3), idx(4), facet)
       end do

       if (NEKO_BCKND_DEVICE .eq. 1) then
          call simcomp%area_msk%copy_from(HOST_TO_DEVICE, .true.)
       end if
    end if

    call simcomp%output_controller%init(0.0_rp, 1.0_rp, "tsteps", 2.0_rp)
    call simcomp%csv_output%init(csv_name, &
         header = "tstep,time,max,integral,average,min", overwrite = .true.)
    call simcomp%csv_row%init(6)
    simcomp%csv_output_enabled = .true.
  end subroutine init_boundary_operation_for_csv_test

  subroutine build_single_hex_fixture(msh, Xh, dof, gs, coef)
    type(mesh_t), intent(inout) :: msh
    type(space_t), intent(inout) :: Xh
    type(dofmap_t), intent(inout) :: dof
    type(gs_t), intent(inout) :: gs
    type(coef_t), intent(inout) :: coef
    type(point_t) :: p(8)

    call p(1)%init(0d0, 0d0, 0d0)
    call p(1)%set_id(1)
    call p(2)%init(1d0, 0d0, 0d0)
    call p(2)%set_id(2)
    call p(3)%init(0d0, 1d0, 0d0)
    call p(3)%set_id(4)
    call p(4)%init(1d0, 1d0, 0d0)
    call p(4)%set_id(3)
    call p(5)%init(0d0, 0d0, 1d0)
    call p(5)%set_id(5)
    call p(6)%init(1d0, 0d0, 1d0)
    call p(6)%set_id(6)
    call p(7)%init(1d0, 1d0, 1d0)
    call p(7)%set_id(7)
    call p(8)%init(0d0, 1d0, 1d0)
    call p(8)%set_id(8)

    call msh%init(3, 1)
    call msh%add_element(1, 1, p(1), p(2), p(4), p(3), &
         p(5), p(6), p(7), p(8))
    call msh%generate_conn()

    call Xh%init(GLL, lx_test, lx_test, lx_test)
    call dof%init(msh, Xh)
    call gs%init(dof)
    call coef%init(gs)
  end subroutine build_single_hex_fixture

  subroutine label_x_faces(msh)
    type(mesh_t), intent(inout) :: msh

    call msh%mark_labeled_facet(1, 1, 1)
    call msh%mark_labeled_facet(2, 1, 2)
    call msh%labeled_zones(1)%finalize()
    call msh%labeled_zones(2)%finalize()
  end subroutine label_x_faces

  subroutine delete_file_if_exists(fname)
    character(len=*), intent(in) :: fname
    logical :: exists
    integer :: unit

    inquire(file = fname, exist = exists)
    if (.not. exists) then
       return
    end if

    open(newunit = unit, file = fname, status = "old")
    close(unit, status = "delete")
  end subroutine delete_file_if_exists

end module test_boundary_operation
